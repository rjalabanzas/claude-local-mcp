diff --git a/cmd/mcp-stdio/typefix.go b/cmd/mcp-stdio/typefix.go
new file mode 100644
index 0000000..f798a2d
--- /dev/null
+++ b/cmd/mcp-stdio/typefix.go
@@ -0,0 +1,416 @@
+package main
+
+// typefix.go folds the logic of tw_typefix_proxy.py into the binary itself.
+//
+// Why this exists: the tool schemas advertise optional, typed params as
+// anyOf:[{type:T},{type:null}]. MCP clients (notably Claude Desktop) flatten
+// that to a type-less property, so the model sends the value as a bare string
+// and the SDK's schema validation rejects it
+// (e.g. list_tasks(assignee_user_ids=[12345]) -> `has type "string", want "array"`).
+//
+// The old fix was an external Python stdio proxy wrapping the binary. A bundled
+// .mcpb desktop extension can't carry a Python proxy, so the same two-part fix
+// now lives here as MCP receiving middleware on the stdio server:
+//
+//  1. tools/list  — flatten anyOf:[T,null] -> plain type:T in the *advertised*
+//     schema, so a well-behaved client sends correctly-typed values. We copy
+//     the tools first; the server hands back its live *Tool pointers.
+//  2. tools/call  — coerce incoming argument values to each param's declared
+//     type before the SDK validates them (string "5" -> 5, "[1,2]" -> [1,2],
+//     "true" -> true, etc.).
+//
+// The server's validation schema is a separate *jsonschema.Resolved captured at
+// AddTool time and is never re-read from Tool.InputSchema, so flattening the
+// advertised schema cannot weaken validation, and coerced values still satisfy
+// the original anyOf:[T,null] resolved schema.
+
+import (
+	"context"
+	"encoding/json"
+	"math"
+	"strconv"
+	"strings"
+	"sync"
+
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+)
+
+// paramType is the resolved JSON type of a single tool parameter. itemType is
+// only set when typ == "array".
+type paramType struct {
+	typ      string
+	itemType string
+}
+
+// typeFixer learns each tool's parameter types from tools/list responses and
+// uses them to coerce tools/call arguments. Safe for concurrent use.
+type typeFixer struct {
+	mu       sync.RWMutex
+	toolType map[string]map[string]paramType
+}
+
+func newTypeFixer() *typeFixer {
+	return &typeFixer{toolType: make(map[string]map[string]paramType)}
+}
+
+// Name sets mirrored verbatim from tw_typefix_proxy.py so inference matches the
+// proven local behaviour exactly.
+var (
+	numberNames      = map[string]bool{"hours": true}
+	stringArrayNames = map[string]bool{
+		"companynames": true, "emails": true, "domains": true, "tags": true,
+		"deletetags": true, "files": true, "entities": true, "options": true,
+		"predecessors": true,
+	}
+	integerNames = map[string]bool{
+		"id": true, "page": true, "page_size": true, "pagesize": true,
+		"pageoffset": true, "limit": true, "offset": true, "minutes": true,
+		"seconds": true, "days_offset": true, "estimated_minutes": true,
+		"displayorder": true, "progress": true,
+	}
+	boolNames = map[string]bool{
+		"verbose": true, "match_all_tags": true, "billable": true,
+		"include_contents": true, "is_utc": true, "running_timers_only": true,
+		"admin": true, "includedeleted": true, "include_completed_items": true,
+		"include_site_level": true, "only_project_level": true,
+		"only_site_level": true, "show_deleted": true, "isparttime": true,
+		"isprivate": true, "ispublish": true, "isrequiredreading": true,
+		"isfullwidth": true, "isminorchange": true, "notifycustomer": true,
+		"notify_current_user": true, "stop_running_timers": true,
+		"running": true, "enabledforfutureinboxes": true,
+		"readerinlinecommentsenabled": true, "clear_section": true,
+		"new_from_template": true, "to_template": true,
+	}
+)
+
+// inferType guesses a param's type from its name (and JSON-schema default, if
+// any) when the schema carries no explicit type. Mirrors infer_type() in
+// tw_typefix_proxy.py, including the order of the checks. prop may be nil.
+func inferType(name string, prop map[string]any) paramType {
+	if prop != nil {
+		if d, ok := prop["default"]; ok && d != nil {
+			switch v := d.(type) {
+			case bool:
+				return paramType{"boolean", ""}
+			case float64: // all JSON numbers decode to float64
+				if v == math.Trunc(v) {
+					return paramType{"integer", ""}
+				}
+				return paramType{"number", ""}
+			case []any:
+				return paramType{"array", "integer"}
+			case string:
+				return paramType{"string", ""}
+			}
+		}
+	}
+	low := strings.ToLower(name)
+	switch {
+	case strings.HasSuffix(low, "_ids") || strings.HasSuffix(name, "IDs") ||
+		strings.HasSuffix(name, "Ids") || low == "ids":
+		return paramType{"array", "integer"}
+	case stringArrayNames[low]:
+		return paramType{"array", "string"}
+	case numberNames[low]:
+		return paramType{"number", ""}
+	case strings.HasSuffix(low, "_id") || strings.HasSuffix(name, "Id") || integerNames[low]:
+		return paramType{"integer", ""}
+	case boolNames[low] || strings.HasPrefix(low, "is_") || strings.HasPrefix(low, "include_") ||
+		strings.HasPrefix(low, "only_") || strings.HasPrefix(low, "show_") ||
+		strings.HasPrefix(low, "has_"):
+		return paramType{"boolean", ""}
+	}
+	return paramType{"string", ""}
+}
+
+// schemaCopyKeys are the keys lifted from a flattened anyOf/oneOf branch up onto
+// the parent property (matches the proxy's patch_tool).
+var schemaCopyKeys = []string{
+	"type", "items", "enum", "format", "pattern", "properties", "required",
+	"minProperties", "maxProperties", "minimum", "maximum",
+}
+
+// patchSchema flattens anyOf/oneOf:[T,null] -> plain type:T inside a tool's
+// input schema (mutating the map in place) and returns the param->type map used
+// to coerce call arguments. Mirrors patch_tool() in tw_typefix_proxy.py.
+func patchSchema(schema map[string]any) map[string]paramType {
+	tmap := make(map[string]paramType)
+	props, ok := schema["properties"].(map[string]any)
+	if !ok {
+		return tmap
+	}
+	for name, raw := range props {
+		prop, ok := raw.(map[string]any)
+		if !ok {
+			continue
+		}
+
+		// Already has an explicit type — just record it.
+		if t, ok := prop["type"].(string); ok {
+			switch t {
+			case "array":
+				tmap[name] = paramType{"array", itemType(prop)}
+			case "boolean", "integer", "number", "string":
+				tmap[name] = paramType{t, ""}
+			}
+			continue
+		}
+
+		// anyOf / oneOf — flatten the [T, null] union to T.
+		if key := unionKey(prop); key != "" {
+			branches, _ := prop[key].([]any)
+			nonnull := nonNullBranches(branches)
+			switch {
+			case len(nonnull) == 1 && branchType(nonnull[0]) != "":
+				b := nonnull[0]
+				delete(prop, key)
+				for _, k := range schemaCopyKeys {
+					if v, ok := b[k]; ok {
+						prop[k] = v
+					}
+				}
+				if bt, _ := prop["type"].(string); bt == "array" {
+					tmap[name] = paramType{"array", itemType(prop)}
+				} else if bt != "" {
+					tmap[name] = paramType{bt, ""}
+				}
+			default:
+				for _, b := range nonnull {
+					if bt := branchType(b); bt != "" {
+						if bt == "array" {
+							tmap[name] = paramType{"array", itemType(b)}
+						} else {
+							tmap[name] = paramType{bt, ""}
+						}
+						break
+					}
+				}
+			}
+			continue
+		}
+
+		// allOf — leave untouched (proxy does the same).
+		if _, ok := prop["allOf"]; ok {
+			continue
+		}
+
+		// Type-less property — infer from the name and write the type into the
+		// advertised schema so clients send the right shape.
+		pt := inferType(name, prop)
+		if pt.typ == "array" {
+			prop["type"] = "array"
+			if _, ok := prop["items"]; !ok {
+				it := pt.itemType
+				if it == "" {
+					it = "integer"
+				}
+				prop["items"] = map[string]any{"type": it}
+			}
+		} else {
+			prop["type"] = pt.typ
+		}
+		tmap[name] = pt
+	}
+	return tmap
+}
+
+func unionKey(prop map[string]any) string {
+	if _, ok := prop["anyOf"]; ok {
+		return "anyOf"
+	}
+	if _, ok := prop["oneOf"]; ok {
+		return "oneOf"
+	}
+	return ""
+}
+
+func nonNullBranches(branches []any) []map[string]any {
+	var out []map[string]any
+	for _, b := range branches {
+		if bm, ok := b.(map[string]any); ok {
+			if t, _ := bm["type"].(string); t != "null" {
+				out = append(out, bm)
+			}
+		}
+	}
+	return out
+}
+
+func branchType(b map[string]any) string {
+	t, _ := b["type"].(string)
+	return t
+}
+
+func itemType(prop map[string]any) string {
+	if items, ok := prop["items"].(map[string]any); ok {
+		if t, ok := items["type"].(string); ok {
+			return t
+		}
+	}
+	return ""
+}
+
+// coerce converts val to the declared type where it can, leaving it untouched
+// otherwise. Mirrors coerce() in tw_typefix_proxy.py.
+func coerce(val any, typ, item string) any {
+	switch typ {
+	case "boolean":
+		switch v := val.(type) {
+		case bool:
+			return v
+		case string:
+			switch strings.ToLower(strings.TrimSpace(v)) {
+			case "true", "1", "yes":
+				return true
+			case "false", "0", "no":
+				return false
+			}
+		}
+		return val
+	case "integer":
+		switch v := val.(type) {
+		case bool:
+			return v // don't turn bools into ints
+		case float64:
+			if v == math.Trunc(v) {
+				return int64(v)
+			}
+			return val
+		case string:
+			if n, err := strconv.ParseInt(strings.TrimSpace(v), 10, 64); err == nil {
+				return n
+			}
+		}
+		return val
+	case "number":
+		switch v := val.(type) {
+		case float64:
+			return v
+		case string:
+			if f, err := strconv.ParseFloat(strings.TrimSpace(v), 64); err == nil {
+				return f
+			}
+		}
+		return val
+	case "array":
+		switch v := val.(type) {
+		case []any:
+			if item != "" {
+				out := make([]any, len(v))
+				for i, x := range v {
+					out[i] = coerce(x, item, "")
+				}
+				return out
+			}
+			return v
+		case string:
+			s := strings.TrimSpace(v)
+			if strings.HasPrefix(s, "[") {
+				var arr []any
+				if json.Unmarshal([]byte(s), &arr) == nil {
+					out := make([]any, len(arr))
+					for i, x := range arr {
+						out[i] = coerce(x, item, "")
+					}
+					return out
+				}
+			}
+			out := []any{}
+			for _, p := range strings.Split(s, ",") {
+				if p = strings.TrimSpace(p); p != "" {
+					out = append(out, coerce(p, item, ""))
+				}
+			}
+			return out
+		}
+		return val
+	}
+	return val
+}
+
+// Middleware returns receiving middleware that coerces tools/call arguments and
+// flattens tools/list schemas.
+func (tf *typeFixer) Middleware() mcp.Middleware {
+	return func(next mcp.MethodHandler) mcp.MethodHandler {
+		return func(ctx context.Context, method string, req mcp.Request) (mcp.Result, error) {
+			if method == "tools/call" {
+				tf.coerceCall(req)
+			}
+			res, err := next(ctx, method, req)
+			if err == nil && method == "tools/list" {
+				res = tf.flattenList(res)
+			}
+			return res, err
+		}
+	}
+}
+
+// coerceCall rewrites the raw arguments of a tools/call request so each value
+// matches its parameter's declared type.
+func (tf *typeFixer) coerceCall(req mcp.Request) {
+	ctr, ok := req.(*mcp.CallToolRequest)
+	if !ok || ctr.Params == nil || len(ctr.Params.Arguments) == 0 {
+		return
+	}
+	tf.mu.RLock()
+	tmap := tf.toolType[ctr.Params.Name]
+	tf.mu.RUnlock()
+
+	var args map[string]any
+	if err := json.Unmarshal(ctr.Params.Arguments, &args); err != nil {
+		return
+	}
+	for k, v := range args {
+		pt, known := tmap[k]
+		if !known {
+			// Tool never listed this session (e.g. a client that cached the
+			// list): fall back to name-based inference. When the tool *is*
+			// known but the key isn't a declared param, leave it alone.
+			if tmap != nil {
+				continue
+			}
+			pt = inferType(k, nil)
+		}
+		args[k] = coerce(v, pt.typ, pt.itemType)
+	}
+	if raw, err := json.Marshal(args); err == nil {
+		ctr.Params.Arguments = raw
+	}
+}
+
+// flattenList returns a copy of a tools/list result with each tool's input
+// schema flattened, and records the per-tool type maps for coercion. The server
+// hands back its live *Tool pointers, so we never mutate them in place.
+func (tf *typeFixer) flattenList(res mcp.Result) mcp.Result {
+	ltr, ok := res.(*mcp.ListToolsResult)
+	if !ok {
+		return res
+	}
+	out := *ltr
+	out.Tools = make([]*mcp.Tool, len(ltr.Tools))
+	learned := make(map[string]map[string]paramType, len(ltr.Tools))
+
+	for i, tool := range ltr.Tools {
+		if tool == nil {
+			continue
+		}
+		tc := *tool // shallow copy; only InputSchema is replaced
+		if tool.InputSchema != nil {
+			if raw, err := json.Marshal(tool.InputSchema); err == nil {
+				var schema map[string]any
+				if json.Unmarshal(raw, &schema) == nil {
+					learned[tool.Name] = patchSchema(schema)
+					tc.InputSchema = schema
+				}
+			}
+		}
+		out.Tools[i] = &tc
+	}
+
+	tf.mu.Lock()
+	for name, m := range learned {
+		tf.toolType[name] = m
+	}
+	tf.mu.Unlock()
+	return &out
+}
