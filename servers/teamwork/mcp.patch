+++ b/internal/twdesk/file_download.go
@@ -0,0 +1,139 @@
+package twdesk
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/config"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+)
+
+// List of methods available in the Teamwork.com MCP service.
+const (
+	MethodFileDownload toolsets.Method = "twdesk-download_file"
+)
+
+// deskFileGetResponse models the subset of the Teamwork Desk
+// GET /files/{id}.json response that we need. The desksdkgo File model does not
+// expose downloadURL/size, so we parse the raw body ourselves rather than going
+// through client.Files.Get (which decodes into the typed struct and drops those
+// fields). Same reason the Projects download_file tool reads the raw body.
+type deskFileGetResponse struct {
+	File struct {
+		ID          int    `json:"id"`
+		Filename    string `json:"filename"`
+		MIMEType    string `json:"mimeType"`
+		Size        int64  `json:"size"`
+		DownloadURL string `json:"downloadURL"`
+	} `json:"file"`
+}
+
+// FileDownload retrieves a Teamwork Desk file/attachment by its ID and returns
+// its pre-signed download URL plus metadata. The download URL is short-lived and
+// pre-authenticated, so it can be fetched directly to read the file contents
+// (e.g. a PDF attached to a ticket) without a Teamwork token.
+func FileDownload(httpClient *http.Client) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodFileDownload),
+			Annotations: &mcp.ToolAnnotations{
+				Title:        "Download File",
+				ReadOnlyHint: true,
+			},
+			Description: "Retrieve a Desk file/attachment by its file ID and return a pre-signed download URL " +
+				"plus metadata (filename, MIME type, size). The URL is pre-authenticated and can be fetched " +
+				"directly to read the file's contents. File IDs come from a ticket's files list.",
+			InputSchema: &jsonschema.Schema{
+				Type:                 "object",
+				AdditionalProperties: falseSchema(),
+				Properties: map[string]*jsonschema.Schema{
+					"fileID": {
+						Type:        "integer",
+						Description: "The ID of the Desk file/attachment to retrieve (as listed in a ticket's files).",
+					},
+				},
+				Required: []string{"fileID"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			arguments, err := helpers.NewToolArguments(request)
+			if err != nil {
+				return helpers.NewToolResultTextError("%v", err), nil
+			}
+
+			fileID, err := arguments.RequireInt("fileID")
+			if err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+			if fileID <= 0 {
+				return helpers.NewToolResultTextError("fileID must be a positive integer"), nil
+			}
+
+			// Derive the base URL and bearer token the same way ClientFromContext
+			// does, so this raw request authenticates identically to the SDK client.
+			baseURL := "https://api.teamwork.com/desk/api/v2"
+			if customerURL, ok := config.CustomerURLFromContext(ctx); ok {
+				customerURL = strings.TrimSuffix(customerURL, "/")
+				baseURL = customerURL + "/desk/api/v2"
+			}
+
+			uri := fmt.Sprintf("%s/files/%d.json", baseURL, fileID)
+			req, err := http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to build request: %s", err.Error()), nil
+			}
+			if bearerToken, ok := config.BearerTokenFromContext(ctx); ok {
+				req.Header.Set("Authorization", "Bearer "+bearerToken)
+			}
+			req.Header.Set("Accept", "application/json")
+
+			client := httpClient
+			if client == nil {
+				client = http.DefaultClient
+			}
+			resp, err := client.Do(req)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to fetch file %d: %s", fileID, err.Error()), nil
+			}
+			defer func() { _ = resp.Body.Close() }()
+
+			body, err := io.ReadAll(resp.Body)
+			if err != nil {
+				return nil, fmt.Errorf("failed to read response body: %w", err)
+			}
+			if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+				return helpers.NewToolResultTextError(
+					"failed to fetch file %d: status %d (body: %s)",
+					fileID, resp.StatusCode, strings.TrimSpace(string(body)),
+				), nil
+			}
+
+			var parsed deskFileGetResponse
+			if err := json.Unmarshal(body, &parsed); err != nil {
+				return helpers.NewToolResultTextError(
+					"failed to parse file response: %s (body: %s)", err.Error(), strings.TrimSpace(string(body)),
+				), nil
+			}
+			if parsed.File.DownloadURL == "" {
+				return helpers.NewToolResultTextError(
+					"file %d has no download URL (body: %s)", fileID, strings.TrimSpace(string(body)),
+				), nil
+			}
+
+			return helpers.NewToolResultJSON(map[string]any{
+				"id":          parsed.File.ID,
+				"filename":    parsed.File.Filename,
+				"mimeType":    parsed.File.MIMEType,
+				"size":        parsed.File.Size,
+				"downloadURL": parsed.File.DownloadURL,
+			})
+		},
+	}
+}
