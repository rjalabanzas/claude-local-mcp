@@ -0,0 +1,148 @@
+package twprojects_test
+
+import (
+	"encoding/json"
+	"net/http"
+	"net/http/httptest"
+	"os"
+	"path/filepath"
+	"strings"
+	"testing"
+
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/testutil"
+	"github.com/teamwork/mcp/internal/twprojects"
+)
+
+// downloadResultSavedTo digs the saved path out of the structured tool result.
+func downloadResultSavedTo(t *testing.T, result mcp.Result) string {
+	t.Helper()
+	callResult, ok := result.(*mcp.CallToolResult)
+	if !ok {
+		t.Fatalf("unexpected result type %T", result)
+	}
+	if callResult.IsError {
+		var msg string
+		for _, c := range callResult.Content {
+			if tc, ok := c.(*mcp.TextContent); ok {
+				msg += tc.Text
+			}
+		}
+		t.Fatalf("tool returned error: %s", msg)
+	}
+	var payload struct {
+		SavedTo  string `json:"saved_to"`
+		FileName string `json:"file_name"`
+		Bytes    int64  `json:"bytes"`
+	}
+	for _, c := range callResult.Content {
+		if tc, ok := c.(*mcp.TextContent); ok {
+			if err := json.Unmarshal([]byte(tc.Text), &payload); err == nil && payload.SavedTo != "" {
+				return payload.SavedTo
+			}
+		}
+	}
+	t.Fatalf("could not find saved_to in result content")
+	return ""
+}
+
+// TestDownloadFileByVersionID covers the search-driven path: the caller passes
+// a file-version ID, /files/{id}.json 404s, and the tool resolves the version
+// to its parent file before downloading.
+func TestDownloadFileByVersionID(t *testing.T) {
+	const versionID = "999"
+	const parentID = "123"
+	const contents = "hello from teamwork"
+
+	// Stand-in for the signed download URL the file metadata points at.
+	blob := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
+		_, _ = w.Write([]byte(contents))
+	}))
+	defer blob.Close()
+
+	fileBody := []byte(`{"file":{"name":"report.pdf","download-URL":"` + blob.URL + `"}}`)
+	versionBody := []byte(`{"fileVersion":{"file":{"id":"` + parentID + `"},"name":"report.pdf"}}`)
+
+	mcpServer := testutil.ProjectsMCPServerRoutedMock(t, []testutil.ProjectsMockRoute{
+		// The version-ID file lookup must 404 to trigger the fallback.
+		{Match: "/files/" + versionID + ".json", Status: http.StatusNotFound,
+			Body: []byte(`{"MESSAGE":"Not Found","STATUS":"Error"}`)},
+		// The version endpoint resolves the parent file ID.
+		{Match: "/fileversions/" + versionID + ".json", Status: http.StatusOK, Body: versionBody},
+		// The parent file lookup yields the download URL.
+		{Match: "/files/" + parentID + ".json", Status: http.StatusOK, Body: fileBody},
+	}, http.StatusNotFound, []byte(`{"MESSAGE":"Not Found","STATUS":"Error"}`))
+
+	outPath := filepath.Join(t.TempDir(), "report.pdf")
+	testutil.ExecuteToolRequest(t, mcpServer, twprojects.MethodDownloadFile.String(), map[string]any{
+		"file_id":  float64(999),
+		"out_path": outPath,
+	}, testutil.ExecuteToolRequestWithCheckMessage(func(t *testing.T, result mcp.Result) {
+		saved := downloadResultSavedTo(t, result)
+		if saved != outPath {
+			t.Errorf("saved_to = %q, want %q", saved, outPath)
+		}
+		got, err := os.ReadFile(outPath)
+		if err != nil {
+			t.Fatalf("failed to read downloaded file: %v", err)
+		}
+		if string(got) != contents {
+			t.Errorf("downloaded contents = %q, want %q", string(got), contents)
+		}
+	}))
+}
+
+// TestDownloadFileByFileID covers the direct path: a real file ID resolves on
+// the first /files/{id}.json call with no version fallback.
+func TestDownloadFileByFileID(t *testing.T) {
+	const fileID = "456"
+	const contents = "direct download"
+
+	blob := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
+		_, _ = w.Write([]byte(contents))
+	}))
+	defer blob.Close()
+
+	fileBody := []byte(`{"file":{"name":"direct.txt","download-URL":"` + blob.URL + `"}}`)
+	mcpServer := testutil.ProjectsMCPServerRoutedMock(t, []testutil.ProjectsMockRoute{
+		{Match: "/files/" + fileID + ".json", Status: http.StatusOK, Body: fileBody},
+	}, http.StatusNotFound, nil)
+
+	outPath := filepath.Join(t.TempDir(), "direct.txt")
+	testutil.ExecuteToolRequest(t, mcpServer, twprojects.MethodDownloadFile.String(), map[string]any{
+		"file_id":  float64(456),
+		"out_path": outPath,
+	}, testutil.ExecuteToolRequestWithCheckMessage(func(t *testing.T, result mcp.Result) {
+		if got := downloadResultSavedTo(t, result); got != outPath {
+			t.Errorf("saved_to = %q, want %q", got, outPath)
+		}
+	}))
+}
+
+// TestDownloadFileNotFound covers a genuinely missing ID: both the file and the
+// file-version lookups 404, so the tool returns a clear error.
+func TestDownloadFileNotFound(t *testing.T) {
+	mcpServer := testutil.ProjectsMCPServerRoutedMock(t, nil,
+		http.StatusNotFound, []byte(`{"MESSAGE":"Not Found","STATUS":"Error"}`))
+
+	testutil.ExecuteToolRequest(t, mcpServer, twprojects.MethodDownloadFile.String(), map[string]any{
+		"file_id": float64(404404),
+	}, testutil.ExecuteToolRequestWithCheckMessage(func(t *testing.T, result mcp.Result) {
+		callResult, ok := result.(*mcp.CallToolResult)
+		if !ok {
+			t.Fatalf("unexpected result type %T", result)
+		}
+		if !callResult.IsError {
+			t.Fatalf("expected an error result for a missing file ID")
+		}
+		var msg string
+		for _, c := range callResult.Content {
+			if tc, ok := c.(*mcp.TextContent); ok {
+				msg += tc.Text
+			}
+		}
+		if !strings.Contains(msg, "failed to fetch file metadata") {
+			t.Errorf("error message = %q, want it to mention metadata fetch failure", msg)
+		}
+	}))
+}
