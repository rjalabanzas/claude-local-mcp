@@ -0,0 +1,633 @@
+package twprojects
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"net/url"
+	"os"
+	"path/filepath"
+	"sort"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// Cloud-storage (SharePoint/OneDrive/Google Drive) integration tools.
+//
+// Teamwork brokers all of this through the Teamwork bearer token:
+//   - browse:  GET  /cloudstorage/folders.json    (list a connected folder)
+//   - upload:  GET  /cloudstorage/token.json  ->  Microsoft Graph PUT .../content
+//   - link:    PUT  /cloudstorage/files/link.json  (register the file in the project)
+//
+// The upload is the only leg that leaves Teamwork: token.json returns a
+// short-lived Microsoft Graph access token + driveId, and the file bytes are
+// PUT straight to graph.microsoft.com. Everything else is standard Teamwork v1.
+const (
+	MethodCloudStorageBrowse toolsets.Method = "twprojects-browse_cloud_storage"
+	MethodCloudStorageUpload toolsets.Method = "twprojects-upload_to_cloud_storage"
+	MethodCloudFileLink      toolsets.Method = "twprojects-link_cloud_file"
+)
+
+// ---------------------------------------------------------------------------
+// browse_cloud_storage
+// ---------------------------------------------------------------------------
+
+type cloudFoldersRequest struct {
+	ProjectID int64
+	Provider  string
+	FolderID  string // empty => connected root
+}
+
+func (r cloudFoldersRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	q := url.Values{}
+	q.Set("projectId", fmt.Sprintf("%d", r.ProjectID))
+	q.Set("provider", r.Provider)
+	q.Set("mode", "uploadFiles")
+	q.Set("page", "1")
+	q.Set("pageSize", "25000")
+	q.Set("refresh", "true")
+	if r.FolderID != "" {
+		q.Set("folder", r.FolderID)
+		q.Set("folderid", r.FolderID)
+	}
+	uri := fmt.Sprintf("%s/cloudstorage/folders.json?%s", server, q.Encode())
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+type rawFolderEntry struct {
+	ID       string      `json:"id"`
+	FileName string      `json:"fileName"`
+	IsDir    bool        `json:"isDir"`
+	Size     json.Number `json:"size"`
+	Path     string      `json:"path"`
+	Type     string      `json:"type"`
+	Modified string      `json:"modified"`
+}
+
+type rawFoldersResponse struct {
+	Status string `json:"STATUS"`
+	Folder struct {
+		Name     string           `json:"name"`
+		Contents []rawFolderEntry `json:"contents"`
+	} `json:"folder"`
+	FolderID          string `json:"folderId"`
+	ParentFolderID    string `json:"parentFolderId"`
+	CanBrowseUpFolder bool   `json:"canBrowseUpAFolder"`
+}
+
+// BrowseCloudStorage lists the files and subfolders of a connected cloud-storage
+// (SharePoint/OneDrive/Google Drive) folder on a project, returning each entry's
+// id, name, whether it is a folder, size and drive path. The ids and path are
+// exactly what link_cloud_file needs; a subfolder's id is passed back as
+// folder_id to drill in.
+func BrowseCloudStorage(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodCloudStorageBrowse),
+			Description: "List the files and subfolders of a connected cloud-storage folder (SharePoint, " +
+				"OneDrive or Google Drive) on a project. Returns each entry's id, name, is_folder, size and " +
+				"drive path. Omit folder_id to list the project's connected root; pass a subfolder's id (from " +
+				"a previous call) as folder_id to drill into it. Use the returned file id/name/path/size with " +
+				"link_cloud_file to link a file to a task.",
+			Annotations: &mcp.ToolAnnotations{
+				Title:        "Browse Cloud Storage",
+				ReadOnlyHint: true,
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"project_id": {
+						Type:        "integer",
+						Description: "The project whose connected cloud storage to browse.",
+					},
+					"folder_id": {
+						Description: "Optional folder id to list. Omit to list the connected root folder.",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+					"provider": {
+						Description: "Cloud provider: sharepoint (default), onedrivebusiness, onedrive or googledrive.",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+				},
+				Required: []string{"project_id"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+			var projectID int64
+			var folderID, provider string
+			if err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&projectID, "project_id"),
+				helpers.OptionalParam(&folderID, "folder_id"),
+				helpers.OptionalParam(&provider, "provider"),
+			); err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+			if provider == "" {
+				provider = "sharepoint"
+			}
+
+			resp, err := twapi.ExecuteRaw(ctx, engine, cloudFoldersRequest{
+				ProjectID: projectID, Provider: provider, FolderID: folderID,
+			})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to browse cloud storage")
+			}
+			body, _ := io.ReadAll(resp.Body)
+			_ = resp.Body.Close()
+			if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(resp, "failed to browse cloud storage"), "failed to browse cloud storage")
+			}
+			var decoded rawFoldersResponse
+			if err := json.Unmarshal(body, &decoded); err != nil {
+				return helpers.NewToolResultTextError("failed to parse folder listing: %s", err.Error()), nil
+			}
+
+			type entry struct {
+				ID       string `json:"id"`
+				Name     string `json:"name"`
+				IsFolder bool   `json:"is_folder"`
+				Size     string `json:"size"`
+				Path     string `json:"path"`
+				Modified string `json:"modified,omitempty"`
+			}
+			out := struct {
+				ProjectID         int64   `json:"project_id"`
+				Provider          string  `json:"provider"`
+				FolderID          string  `json:"folder_id"`
+				ParentFolderID    string  `json:"parent_folder_id"`
+				CanBrowseUpFolder bool    `json:"can_browse_up_a_folder"`
+				Returned          int     `json:"returned"`
+				Entries           []entry `json:"entries"`
+			}{
+				ProjectID: projectID, Provider: provider,
+				FolderID: decoded.FolderID, ParentFolderID: decoded.ParentFolderID,
+				CanBrowseUpFolder: decoded.CanBrowseUpFolder,
+			}
+			for _, c := range decoded.Folder.Contents {
+				out.Entries = append(out.Entries, entry{
+					ID: c.ID, Name: c.FileName, IsFolder: c.IsDir,
+					Size: c.Size.String(), Path: c.Path, Modified: c.Modified,
+				})
+			}
+			out.Returned = len(out.Entries)
+			return helpers.NewToolResultJSON(out)
+		},
+	}
+}
+
+// ---------------------------------------------------------------------------
+// upload_to_cloud_storage
+// ---------------------------------------------------------------------------
+
+type cloudTokenRequest struct {
+	ProjectID int64
+	Provider  string
+}
+
+func (r cloudTokenRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	q := url.Values{}
+	q.Set("projectId", fmt.Sprintf("%d", r.ProjectID))
+	q.Set("provider", r.Provider)
+	uri := fmt.Sprintf("%s/cloudstorage/token.json?%s", server, q.Encode())
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+// UploadToCloudStorage uploads a local file into a connected cloud-storage folder
+// (via a Teamwork-brokered Microsoft Graph token) and returns the new file's
+// descriptor (id, name, path, size) ready to pass to link_cloud_file.
+func UploadToCloudStorage(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodCloudStorageUpload),
+			Description: "Upload a local file into a connected cloud-storage folder (SharePoint/OneDrive) and " +
+				"return the new file's id, name, drive path and size. Provide the absolute local file_path, the " +
+				"project_id, and the target folder_id (from browse_cloud_storage, e.g. the current month's " +
+				"folder). Optionally set file_name to rename on upload. This does NOT attach the file to a task " +
+				"or add it to the project's Files area - pass the returned descriptor to link_cloud_file for " +
+				"that. Only supports files up to 4MB.",
+			Annotations: &mcp.ToolAnnotations{
+				Title: "Upload to Cloud Storage",
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"project_id": {Type: "integer", Description: "The project whose connected cloud storage to upload into."},
+					"folder_id":  {Type: "string", Description: "Target folder id (from browse_cloud_storage) to upload the file into."},
+					"file_path":  {Type: "string", Description: "Absolute path to the local file to upload."},
+					"file_name": {
+						Description: "Optional name to store the file as (rename on upload). Defaults to the file_path base name.",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+					"provider": {
+						Description: "Cloud provider: sharepoint (default), onedrivebusiness or onedrive.",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+				},
+				Required: []string{"project_id", "folder_id", "file_path"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+			var projectID int64
+			var folderID, filePath, fileName, provider string
+			if err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&projectID, "project_id"),
+				helpers.RequiredParam(&folderID, "folder_id"),
+				helpers.RequiredParam(&filePath, "file_path"),
+				helpers.OptionalParam(&fileName, "file_name"),
+				helpers.OptionalParam(&provider, "provider"),
+			); err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+			if provider == "" {
+				provider = "sharepoint"
+			}
+			data, err := os.ReadFile(filePath)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to read file %q: %s", filePath, err.Error()), nil
+			}
+			if len(data) > 4*1024*1024 {
+				return helpers.NewToolResultTextError(
+					"file is %d bytes; this tool only supports uploads up to 4MB", len(data)), nil
+			}
+			if fileName == "" {
+				fileName = filepath.Base(filePath)
+			}
+
+			// Step 1: broker a Microsoft Graph token + driveId via Teamwork.
+			tokResp, err := twapi.ExecuteRaw(ctx, engine, cloudTokenRequest{ProjectID: projectID, Provider: provider})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to get cloud-storage upload token")
+			}
+			tokBody, _ := io.ReadAll(tokResp.Body)
+			_ = tokResp.Body.Close()
+			if tokResp.StatusCode < 200 || tokResp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(tokResp, "failed to get cloud-storage upload token"),
+					"failed to get cloud-storage upload token")
+			}
+			var tok struct {
+				Token   string `json:"token"`
+				DriveID string `json:"driveId"`
+				Status  string `json:"status"`
+			}
+			if err := json.Unmarshal(tokBody, &tok); err != nil || tok.Token == "" || tok.DriveID == "" {
+				return helpers.NewToolResultTextError("cloud-storage token response missing token/driveId"), nil
+			}
+
+			// Step 2: PUT the bytes straight to Microsoft Graph.
+			graphURL := fmt.Sprintf(
+				"https://graph.microsoft.com/v1.0/drives/%s/items/%s:/%s:/content",
+				tok.DriveID, folderID, url.PathEscape(fileName),
+			)
+			gReq, err := http.NewRequestWithContext(ctx, http.MethodPut, graphURL, bytes.NewReader(data))
+			if err != nil {
+				return nil, fmt.Errorf("failed to build graph upload request: %w", err)
+			}
+			gReq.Header.Set("Authorization", "Bearer "+tok.Token)
+			gReq.Header.Set("Content-Type", "application/octet-stream")
+			gResp, err := http.DefaultClient.Do(gReq)
+			if err != nil {
+				return helpers.NewToolResultTextError("graph upload failed: %s", err.Error()), nil
+			}
+			gBody, _ := io.ReadAll(gResp.Body)
+			_ = gResp.Body.Close()
+			if gResp.StatusCode < 200 || gResp.StatusCode >= 300 {
+				return helpers.NewToolResultTextError(
+					"graph upload returned status %d: %s", gResp.StatusCode, strings.TrimSpace(string(gBody))), nil
+			}
+			var item struct {
+				ID              string      `json:"id"`
+				Name            string      `json:"name"`
+				Size            json.Number `json:"size"`
+				WebURL          string      `json:"webUrl"`
+				ParentReference struct {
+					DriveID string `json:"driveId"`
+					Path    string `json:"path"`
+				} `json:"parentReference"`
+			}
+			if err := json.Unmarshal(gBody, &item); err != nil || item.ID == "" {
+				return helpers.NewToolResultTextError("failed to parse graph upload response: %s", strings.TrimSpace(string(gBody))), nil
+			}
+
+			// Normalise the containing-folder path to the /drives/{driveId}/root:… form
+			// that link_cloud_file expects.
+			path := item.ParentReference.Path
+			if !strings.HasPrefix(path, "/drives/") {
+				sub := path
+				if i := strings.Index(sub, "root:"); i >= 0 {
+					sub = sub[i+len("root:"):]
+				}
+				path = fmt.Sprintf("/drives/%s/root:%s", tok.DriveID, sub)
+			}
+
+			out := struct {
+				ID       string `json:"id"`
+				Name     string `json:"name"`
+				Path     string `json:"path"`
+				Size     string `json:"size"`
+				Type     string `json:"type"`
+				WebURL   string `json:"web_url,omitempty"`
+				Provider string `json:"provider"`
+				Message  string `json:"message"`
+			}{
+				ID: item.ID, Name: item.Name, Path: path, Size: item.Size.String(),
+				Type: "file", WebURL: item.WebURL, Provider: provider,
+				Message: fmt.Sprintf("Uploaded %q to %s. Pass id/name/path/size to link_cloud_file to link it to a task.", item.Name, provider),
+			}
+			return helpers.NewToolResultJSON(out)
+		},
+	}
+}
+
+// ---------------------------------------------------------------------------
+// link_cloud_file
+// ---------------------------------------------------------------------------
+
+type cloudLinkFile struct {
+	ID   string `json:"id"`
+	Name string `json:"name"`
+	Path string `json:"path"`
+	Size string `json:"size"`
+	Type string `json:"type"`
+}
+
+type cloudLinkRequest struct {
+	ProjectID       int64
+	CategoryID      int64
+	NewCategoryName string
+	AccessRights    string
+	Provider        string
+	Files           []cloudLinkFile
+}
+
+func (r cloudLinkRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	payload := map[string]any{
+		"projectId":       r.ProjectID,
+		"categoryId":      r.CategoryID,
+		"newCategoryName": r.NewCategoryName,
+		"accessRights":    r.AccessRights,
+		"grantAccessTo":   "",
+		"provider":        r.Provider,
+		"files":           r.Files,
+	}
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode link request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/cloudstorage/files/link.json?provider=%s", server, url.QueryEscape(r.Provider))
+	req, err := http.NewRequestWithContext(ctx, http.MethodPut, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// taskAttachmentsSetRequest sets the directly-attached file IDs on a task via
+// the v1 task update endpoint. The v1 "attachments" field takes the full
+// comma-separated set of existing file IDs (it replaces, not appends), so the
+// caller reads the task's current attachments first and passes the union.
+type taskAttachmentsSetRequest struct {
+	TaskID        int64
+	AttachmentIDs string // comma-separated existing file IDs
+}
+
+func (r taskAttachmentsSetRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	payload := map[string]any{"todo-item": map[string]any{"attachments": r.AttachmentIDs}}
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode task attach request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/tasks/%d.json", server, r.TaskID)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPut, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// LinkCloudFile registers a cloud-storage file (already in SharePoint/OneDrive)
+// into a project's Files area and, when task_id is given, attaches it to that
+// task. access_rights defaults to NONE (Teamwork does not create a sharing link;
+// access relies on the file's own SharePoint permissions) which avoids the
+// external-sharing restriction that a "view"/"edit" grant triggers.
+func LinkCloudFile(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodCloudFileLink),
+			Description: "Link a cloud-storage file that already exists in SharePoint/OneDrive into a project's " +
+				"Files area, and optionally attach it to a task. Provide project_id and the file's id, name, " +
+				"path and size (from browse_cloud_storage or upload_to_cloud_storage). When task_id is given, " +
+				"the file is also attached to that task (appended to its existing attachments). access_rights " +
+				"defaults to NONE - Teamwork won't create a sharing link, so access follows the file's own " +
+				"SharePoint permissions; this avoids the \"external sharing restricted\" error that view/edit " +
+				"grants can trigger.",
+			Annotations: &mcp.ToolAnnotations{
+				Title: "Link Cloud File",
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"project_id": {Type: "integer", Description: "The project to link the file into."},
+					"file_id":    {Type: "string", Description: "The cloud-storage file id (driveItem id)."},
+					"file_name":  {Type: "string", Description: "The file's name (e.g. \"PO12345 - Vendor.pdf\")."},
+					"file_path":  {Type: "string", Description: "The file's containing-folder drive path, e.g. /drives/{driveId}/root:/General/Invoices/2026/07. July"},
+					"file_size":  {Type: "string", Description: "The file size in bytes, as a string."},
+					"task_id": {
+						Description: "Optional task to attach the linked file to. Omit to only add it to the project Files area.",
+						AnyOf:       []*jsonschema.Schema{{Type: "integer"}, {Type: "null"}},
+					},
+					"category_id": {
+						Description: "Optional Files-area category id to file it under (default 0 = No Category).",
+						AnyOf:       []*jsonschema.Schema{{Type: "integer"}, {Type: "null"}},
+					},
+					"new_category_name": {
+						Description: "Optional category name (default \"No Category\").",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+					"access_rights": {
+						Description: "Sharing access Teamwork grants: NONE (default, recommended), view or edit. Use NONE unless you specifically need Teamwork to grant project members access via a sharing link.",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+					"provider": {
+						Description: "Cloud provider: sharepoint (default), onedrivebusiness, onedrive or googledrive.",
+						AnyOf:       []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+				},
+				Required: []string{"project_id", "file_id", "file_name", "file_path", "file_size"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+			var projectID, taskID, categoryID int64
+			var fileID, fileName, filePath, fileSize, newCategoryName, accessRights, provider string
+			if err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&projectID, "project_id"),
+				helpers.RequiredParam(&fileID, "file_id"),
+				helpers.RequiredParam(&fileName, "file_name"),
+				helpers.RequiredParam(&filePath, "file_path"),
+				helpers.RequiredParam(&fileSize, "file_size"),
+				helpers.OptionalNumericParam(&taskID, "task_id"),
+				helpers.OptionalNumericParam(&categoryID, "category_id"),
+				helpers.OptionalParam(&newCategoryName, "new_category_name"),
+				helpers.OptionalParam(&accessRights, "access_rights"),
+				helpers.OptionalParam(&provider, "provider"),
+			); err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+			if provider == "" {
+				provider = "sharepoint"
+			}
+			if accessRights == "" {
+				accessRights = "NONE"
+			}
+			if newCategoryName == "" {
+				newCategoryName = "No Category"
+			}
+
+			// Step 1: register the file in the project's Files area.
+			linkResp, err := twapi.ExecuteRaw(ctx, engine, cloudLinkRequest{
+				ProjectID: projectID, CategoryID: categoryID, NewCategoryName: newCategoryName,
+				AccessRights: accessRights, Provider: provider,
+				Files: []cloudLinkFile{{ID: fileID, Name: fileName, Path: filePath, Size: fileSize, Type: "file"}},
+			})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to link cloud file")
+			}
+			linkBody, _ := io.ReadAll(linkResp.Body)
+			_ = linkResp.Body.Close()
+			if linkResp.StatusCode < 200 || linkResp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(linkResp, "failed to link cloud file"), "failed to link cloud file")
+			}
+			var link struct {
+				Status        string `json:"STATUS"`
+				Message       string `json:"MESSAGE"`
+				SelectedFiles []struct {
+					ID   string `json:"id"`
+					Name string `json:"name"`
+				} `json:"selectedFiles"`
+			}
+			_ = json.Unmarshal(linkBody, &link)
+			if link.Status != "" && !strings.EqualFold(link.Status, "OK") {
+				msg := link.Message
+				if msg == "" {
+					msg = strings.TrimSpace(string(linkBody))
+				}
+				return helpers.NewToolResultTextError("failed to link cloud file: %s", msg), nil
+			}
+			if len(link.SelectedFiles) == 0 || link.SelectedFiles[0].ID == "" {
+				return helpers.NewToolResultTextError(
+					"link succeeded but no Teamwork file id was returned (body: %s)", strings.TrimSpace(string(linkBody))), nil
+			}
+			twFileID := link.SelectedFiles[0].ID
+
+			out := struct {
+				TeamworkFileID string `json:"teamwork_file_id"`
+				Name           string `json:"name"`
+				ProjectID      int64  `json:"project_id"`
+				TaskID         int64  `json:"task_id,omitempty"`
+				AttachedToTask bool   `json:"attached_to_task"`
+				Message        string `json:"message"`
+			}{TeamworkFileID: twFileID, Name: fileName, ProjectID: projectID}
+
+			if taskID == 0 {
+				out.Message = fmt.Sprintf("Linked %q into project %d Files (Teamwork file id %s).", fileName, projectID, twFileID)
+				return helpers.NewToolResultJSON(out)
+			}
+
+			// Step 2: attach to the task, preserving its existing attachments.
+			existing, err := taskAttachmentIDs(ctx, engine, taskID)
+			if err != nil {
+				return helpers.NewToolResultTextError(
+					"file linked (Teamwork id %s) but reading task %d's current attachments failed: %s",
+					twFileID, taskID, err.Error()), nil
+			}
+			ids := unionIDs(existing, twFileID)
+			attResp, err := twapi.ExecuteRaw(ctx, engine, taskAttachmentsSetRequest{
+				TaskID: taskID, AttachmentIDs: strings.Join(ids, ","),
+			})
+			if err != nil {
+				return helpers.NewToolResultTextError(
+					"file linked (Teamwork id %s) but attaching to task %d failed: %s", twFileID, taskID, err.Error()), nil
+			}
+			attBody, _ := io.ReadAll(attResp.Body)
+			_ = attResp.Body.Close()
+			if attResp.StatusCode < 200 || attResp.StatusCode >= 300 {
+				return helpers.NewToolResultTextError(
+					"file linked (Teamwork id %s) but attaching to task %d returned status %d: %s",
+					twFileID, taskID, attResp.StatusCode, strings.TrimSpace(string(attBody))), nil
+			}
+			out.TaskID = taskID
+			out.AttachedToTask = true
+			out.Message = fmt.Sprintf("Linked %q into project %d and attached it to task %d (Teamwork file id %s).",
+				fileName, projectID, taskID, twFileID)
+			return helpers.NewToolResultJSON(out)
+		},
+	}
+}
+
+// taskAttachmentIDs reads a task's currently attached file IDs.
+func taskAttachmentIDs(ctx context.Context, engine *twapi.Engine, taskID int64) ([]string, error) {
+	resp, err := twapi.ExecuteRaw(ctx, engine, taskFilesRequest{TaskID: taskID})
+	if err != nil {
+		return nil, err
+	}
+	body, _ := io.ReadAll(resp.Body)
+	_ = resp.Body.Close()
+	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+		return nil, fmt.Errorf("status %d", resp.StatusCode)
+	}
+	var decoded rawTaskFilesResponse
+	if err := json.Unmarshal(body, &decoded); err != nil {
+		return nil, err
+	}
+	raw := decoded.Project.Files
+	if len(raw) == 0 {
+		raw = decoded.Files
+	}
+	var ids []string
+	for _, f := range raw {
+		if s := f.ID.String(); s != "" && s != "0" {
+			ids = append(ids, s)
+		}
+	}
+	return ids, nil
+}
+
+// unionIDs returns the existing IDs plus newID, de-duplicated and sorted for
+// deterministic output.
+func unionIDs(existing []string, newID string) []string {
+	set := map[string]struct{}{}
+	for _, id := range existing {
+		set[id] = struct{}{}
+	}
+	set[newID] = struct{}{}
+	out := make([]string, 0, len(set))
+	for id := range set {
+		out = append(out, id)
+	}
+	sort.Strings(out)
+	return out
+}
diff --git a/internal/twprojects/file_delete.go b/internal/twprojects/file_delete.go
new file mode 100644
index 0000000..0de5389
--- /dev/null
+++ b/internal/twprojects/file_delete.go
@@ -0,0 +1,116 @@
+package twprojects
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// List of methods available in the Teamwork.com MCP service.
+const (
+	MethodFileDelete toolsets.Method = "twprojects-delete_file"
+)
+
+// fileDeleteRequest is a local HTTP requester for the v1 delete-file endpoint.
+// The SDK models no file delete, so the requester lives here (no twapi-go-sdk
+// edit). It targets a file by its exact ID only — no name matching and no
+// file-version resolution — because the delete is irreversible and must never
+// act on a file other than the one whose ID the caller supplied.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/files/delete-files-id-json
+type fileDeleteRequest struct {
+	FileID int64
+}
+
+// HTTPRequest builds the DELETE request for a single file.
+func (r fileDeleteRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/files/%d.json", server, r.FileID)
+	return http.NewRequestWithContext(ctx, http.MethodDelete, uri, nil)
+}
+
+// DeleteFile permanently deletes a Teamwork file by its exact ID.
+func DeleteFile(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodFileDelete),
+			Description: "Delete a Teamwork file by its exact ID. This is DESTRUCTIVE and should be " +
+				"treated as IRREVERSIBLE: the file (and all of its versions) is marked deleted and " +
+				"removed from the project and all normal views, and there is no undo through this " +
+				"tool or the API. The caller must pass the exact file_id; the tool performs no name " +
+				"matching and no ID resolution, so it will never delete a file other than the one " +
+				"whose ID was given. A file-version ID is not a file ID and will not resolve here — " +
+				"pass the file's own ID.",
+			Annotations: &mcp.ToolAnnotations{
+				Title:           "Delete File",
+				DestructiveHint: new(true),
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"file_id": {
+						Type:        "integer",
+						Description: "The exact Teamwork file ID to permanently delete.",
+					},
+				},
+				Required: []string{"file_id"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var fileID int64
+			err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&fileID, "file_id"),
+			)
+			if err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			resp, err := twapi.ExecuteRaw(ctx, engine, fileDeleteRequest{FileID: fileID})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to delete file")
+			}
+			body, readErr := io.ReadAll(resp.Body)
+			_ = resp.Body.Close()
+			if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(resp, "failed to delete file"),
+					"failed to delete file",
+				)
+			}
+			if readErr != nil {
+				return nil, fmt.Errorf("failed to read response body: %w", readErr)
+			}
+
+			// The v1 endpoint returns 200 with {"STATUS":"OK"} on success, but can
+			// also return 200 with {"STATUS":"Error"} for some failures — treat a
+			// non-OK STATUS as a failure so a bad delete is never reported as success.
+			var status struct {
+				Status  string `json:"STATUS"`
+				Message string `json:"MESSAGE"`
+			}
+			_ = json.Unmarshal(body, &status)
+			if status.Status != "" && !strings.EqualFold(status.Status, "OK") {
+				msg := status.Message
+				if msg == "" {
+					msg = strings.TrimSpace(string(body))
+				}
+				return helpers.NewToolResultTextError("failed to delete file %d: %s", fileID, msg), nil
+			}
+
+			return helpers.NewToolResultText("File %d deleted.", fileID), nil
+		},
+	}
+}
diff --git a/internal/twprojects/file_download.go b/internal/twprojects/file_download.go
new file mode 100644
index 0000000..f5a1241
--- /dev/null
+++ b/internal/twprojects/file_download.go
@@ -0,0 +1,446 @@
+package twprojects
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"mime"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// List of methods available in the Teamwork.com MCP service.
+const (
+	MethodListTaskFiles toolsets.Method = "twprojects-list_task_files"
+	MethodDownloadFile  toolsets.Method = "twprojects-download_file"
+)
+
+var listTaskFilesOutputSchema *jsonschema.Schema
+
+func init() {
+	var err error
+	listTaskFilesOutputSchema, err = jsonschema.For[listTaskFilesResult](&jsonschema.ForOptions{})
+	if err != nil {
+		panic(fmt.Sprintf("failed to generate JSON schema for listTaskFilesResult: %v", err))
+	}
+}
+
+// taskFile is a single file attached to a task, projected into the output shape.
+type taskFile struct {
+	ID          int64  `json:"id"`
+	Name        string `json:"name"`
+	Size        int64  `json:"size"`
+	ContentType string `json:"content_type"`
+	CreatedAt   string `json:"created_at"`
+	UploadedBy  string `json:"uploaded_by"`
+}
+
+// listTaskFilesResult is the structured payload returned by the list tool.
+type listTaskFilesResult struct {
+	Returned int        `json:"returned"`
+	Files    []taskFile `json:"files"`
+}
+
+// taskFilesRequest is a local HTTP requester for the v1 task files endpoint.
+// The SDK has no type for this endpoint, so the requester lives here (no
+// twapi-go-sdk edit).
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/files/get-tasks-task-id-files-json
+type taskFilesRequest struct {
+	TaskID int64
+}
+
+// HTTPRequest builds the GET request for a task's files.
+func (r taskFilesRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/tasks/%d/files.json", server, r.TaskID)
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+// rawTaskFile is the subset of a v1 task-file record the list tool reads. The
+// v1 /tasks/{id}/files.json response uses hyphenated keys and returns id/size as
+// quoted strings (hence json.Number), and carries the uploader's name as two
+// flat fields rather than a nested object.
+type rawTaskFile struct {
+	ID           json.Number `json:"id"`
+	Name         string      `json:"name"`
+	OriginalName string      `json:"originalName"`
+	Size         json.Number `json:"size"`
+	UploadedDate string      `json:"uploaded-date"`
+	FirstName    string      `json:"uploaded-by-user-first-name"`
+	LastName     string      `json:"uploaded-by-user-last-name"`
+}
+
+// rawTaskFilesResponse is the subset of the v1 task-files response the list tool
+// reads. The files array is nested under the returned "project" object; a
+// top-level "files" is kept as a defensive fallback in case a variant of the
+// endpoint returns it there.
+type rawTaskFilesResponse struct {
+	Project struct {
+		Files []rawTaskFile `json:"files"`
+	} `json:"project"`
+	Files []rawTaskFile `json:"files"`
+}
+
+// fileMetaRequest is a local HTTP requester for the v1 single-file endpoint,
+// used to resolve a file's download URL and original name before downloading.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/files/get-files-id-json
+type fileMetaRequest struct {
+	FileID int64
+}
+
+// HTTPRequest builds the GET request for a single file's metadata.
+func (r fileMetaRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/files/%d.json", server, r.FileID)
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+// fileVersionMetaRequest is a local HTTP requester for the v1 single
+// file-version endpoint. Teamwork search results (twprojects-search) return
+// file *version* IDs (type "fileVersions"), which the /files/{id}.json
+// endpoint rejects with 404. This endpoint resolves a version to its parent
+// file, whose ID then drives the normal download flow.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/files/get-files-id-json
+type fileVersionMetaRequest struct {
+	FileVersionID int64
+}
+
+// HTTPRequest builds the GET request for a single file version's metadata.
+func (r fileVersionMetaRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/fileversions/%d.json", server, r.FileVersionID)
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+// downloadFileResult is the structured payload returned by the download tool.
+type downloadFileResult struct {
+	SavedTo  string `json:"saved_to"`
+	FileName string `json:"file_name"`
+	Bytes    int64  `json:"bytes"`
+}
+
+// resolveFileVersionParent resolves a file-version ID to its parent file ID
+// via the v1 /fileversions/{id}.json endpoint. It returns 0 (with no error)
+// when the version endpoint also reports the ID as not found, so callers can
+// fall through to a generic not-found response. The v1 API returns the nested
+// file ID as a JSON string, so it is parsed leniently.
+func resolveFileVersionParent(ctx context.Context, engine *twapi.Engine, versionID int64) (int64, error) {
+	resp, err := twapi.ExecuteRaw(ctx, engine, fileVersionMetaRequest{FileVersionID: versionID})
+	if err != nil {
+		return 0, err
+	}
+	body, readErr := io.ReadAll(resp.Body)
+	_ = resp.Body.Close()
+	if resp.StatusCode == http.StatusNotFound {
+		return 0, nil
+	}
+	if resp.StatusCode != http.StatusOK {
+		return 0, fmt.Errorf("HTTP %d: %s", resp.StatusCode, strings.TrimSpace(string(body)))
+	}
+	if readErr != nil {
+		return 0, fmt.Errorf("failed to read file version metadata body: %w", readErr)
+	}
+
+	var meta struct {
+		FileVersion struct {
+			File struct {
+				ID json.Number `json:"id"`
+			} `json:"file"`
+		} `json:"fileVersion"`
+	}
+	if err := json.Unmarshal(body, &meta); err != nil {
+		return 0, fmt.Errorf("failed to parse file version metadata: %w (body: %s)",
+			err, strings.TrimSpace(string(body)))
+	}
+	parentID, err := meta.FileVersion.File.ID.Int64()
+	if err != nil {
+		return 0, fmt.Errorf("file version %d has no resolvable parent file ID (body: %s)",
+			versionID, strings.TrimSpace(string(body)))
+	}
+	return parentID, nil
+}
+
+// ListTaskFiles lists the files attached to a task.
+func ListTaskFiles(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name:        string(MethodListTaskFiles),
+			Description: "List files attached to a task. Returns file IDs, names, sizes, and uploader info.",
+			Annotations: &mcp.ToolAnnotations{
+				Title:        "List Task Files",
+				ReadOnlyHint: true,
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"task_id": {
+						Type:        "integer",
+						Description: "The ID of the task whose files should be listed.",
+					},
+				},
+				Required: []string{"task_id"},
+			},
+			OutputSchema: helpers.WithOptionalFields(listTaskFilesOutputSchema),
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var taskID int64
+			err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&taskID, "task_id"),
+			)
+			if err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			resp, err := twapi.ExecuteRaw(ctx, engine, taskFilesRequest{TaskID: taskID})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to list task files")
+			}
+			body, readErr := io.ReadAll(resp.Body)
+			_ = resp.Body.Close()
+			if resp.StatusCode != http.StatusOK {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(resp, "failed to list task files"),
+					"failed to list task files",
+				)
+			}
+			if readErr != nil {
+				return nil, fmt.Errorf("failed to read response body: %w", readErr)
+			}
+
+			var decoded rawTaskFilesResponse
+			if err := json.Unmarshal(body, &decoded); err != nil {
+				return nil, fmt.Errorf("failed to decode task files response: %w", err)
+			}
+
+			raw := decoded.Project.Files
+			if len(raw) == 0 {
+				raw = decoded.Files
+			}
+
+			files := make([]taskFile, 0, len(raw))
+			for _, f := range raw {
+				id, _ := f.ID.Int64()
+				size, _ := f.Size.Int64()
+				name := f.Name
+				if name == "" {
+					name = f.OriginalName
+				}
+				contentType := mime.TypeByExtension(filepath.Ext(name))
+				uploadedBy := strings.TrimSpace(f.FirstName + " " + f.LastName)
+				files = append(files, taskFile{
+					ID:          id,
+					Name:        name,
+					Size:        size,
+					ContentType: contentType,
+					CreatedAt:   f.UploadedDate,
+					UploadedBy:  uploadedBy,
+				})
+			}
+
+			result := listTaskFilesResult{
+				Returned: len(files),
+				Files:    files,
+			}
+
+			encoded, err := json.Marshal(result)
+			if err != nil {
+				return nil, fmt.Errorf("failed to encode task files result: %w", err)
+			}
+			return &mcp.CallToolResult{
+				Content: []mcp.Content{
+					&mcp.TextContent{Text: string(encoded)},
+				},
+				StructuredContent: result,
+			}, nil
+		},
+	}
+}
+
+// DownloadFile downloads a Teamwork file by its ID and saves it to local disk.
+// It first resolves the file's signed download URL via the v1 file endpoint,
+// then fetches that URL directly (it carries its own auth and lives outside the
+// /projects/api prefix, so it is not routed through the engine).
+func DownloadFile(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodDownloadFile),
+			Description: "Download a Teamwork file by its ID and save it to a local path. " +
+				"Accepts either a file ID or a file-version ID (Teamwork search results " +
+				"return file-version IDs, type \"fileVersions\"); version IDs are resolved " +
+				"to their parent file automatically. Returns the saved path and file size.",
+			Annotations: &mcp.ToolAnnotations{
+				Title:        "Download File",
+				ReadOnlyHint: true,
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"file_id": {
+						Type: "integer",
+						Description: "The Teamwork file ID (or file-version ID, as returned by " +
+							"twprojects-search) to download.",
+					},
+					"out_path": {
+						Description: "Absolute local path to save the file. If omitted, saves to /tmp/{filename}.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "string"},
+							{Type: "null"},
+						},
+					},
+				},
+				Required: []string{"file_id"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var fileID int64
+			var outPath string
+			err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&fileID, "file_id"),
+				helpers.OptionalParam(&outPath, "out_path"),
+			)
+			if err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			// fetchFileMeta GETs /files/{id}.json and returns the HTTP status
+			// plus the raw body. A separate readErr surfaces body-read failures
+			// without masking the status.
+			fetchFileMeta := func(id int64) (status int, body []byte, readErr error, execErr error) {
+				resp, err := twapi.ExecuteRaw(ctx, engine, fileMetaRequest{FileID: id})
+				if err != nil {
+					return 0, nil, nil, err
+				}
+				b, rErr := io.ReadAll(resp.Body)
+				_ = resp.Body.Close()
+				return resp.StatusCode, b, rErr, nil
+			}
+
+			// Step 1: resolve the download URL and original filename.
+			// `file_id` may be a real file ID or a file-version ID — Teamwork
+			// search (twprojects-search) returns file-version IDs (type
+			// "fileVersions"), which /files/{id}.json rejects with 404. On a 404
+			// we resolve the version to its parent file and retry once.
+			metaStatus, metaBody, readErr, execErr := fetchFileMeta(fileID)
+			if execErr != nil {
+				return helpers.HandleAPIError(execErr, "failed to fetch file metadata")
+			}
+
+			if metaStatus == http.StatusNotFound {
+				parentID, resolveErr := resolveFileVersionParent(ctx, engine, fileID)
+				if resolveErr != nil {
+					return helpers.NewToolResultTextError(
+						"file %d not found, and resolving it as a file-version ID failed: %s",
+						fileID, resolveErr.Error(),
+					), nil
+				}
+				if parentID != 0 {
+					metaStatus, metaBody, readErr, execErr = fetchFileMeta(parentID)
+					if execErr != nil {
+						return helpers.HandleAPIError(execErr, "failed to fetch file metadata")
+					}
+				}
+			}
+
+			if metaStatus != http.StatusOK {
+				return helpers.NewToolResultTextError(
+					"failed to fetch file metadata for %d (HTTP %d): %s",
+					fileID, metaStatus, strings.TrimSpace(string(metaBody)),
+				), nil
+			}
+			if readErr != nil {
+				return nil, fmt.Errorf("failed to read file metadata body: %w", readErr)
+			}
+
+			var meta struct {
+				File struct {
+					Name        string `json:"name"`
+					DownloadURL string `json:"download-URL"`
+				} `json:"file"`
+			}
+			if err := json.Unmarshal(metaBody, &meta); err != nil {
+				return helpers.NewToolResultTextError(
+					"failed to parse file metadata: %s (body: %s)", err.Error(), strings.TrimSpace(string(metaBody)),
+				), nil
+			}
+			if meta.File.DownloadURL == "" {
+				return helpers.NewToolResultTextError(
+					"file %d has no download URL (body: %s)", fileID, strings.TrimSpace(string(metaBody)),
+				), nil
+			}
+
+			fileName := meta.File.Name
+			if outPath == "" {
+				if fileName == "" {
+					fileName = fmt.Sprintf("teamwork-file-%d", fileID)
+				}
+				outPath = filepath.Join(os.TempDir(), fileName)
+			} else if fileName == "" {
+				fileName = filepath.Base(outPath)
+			}
+
+			// Step 2: fetch the signed URL directly (not through the engine).
+			dlReq, err := http.NewRequestWithContext(ctx, http.MethodGet, meta.File.DownloadURL, nil)
+			if err != nil {
+				return nil, fmt.Errorf("failed to build download request: %w", err)
+			}
+			dlResp, err := http.DefaultClient.Do(dlReq)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to download file: %s", err.Error()), nil
+			}
+			defer func() { _ = dlResp.Body.Close() }()
+			if dlResp.StatusCode < 200 || dlResp.StatusCode >= 300 {
+				return helpers.NewToolResultTextError(
+					"download failed with status %d", dlResp.StatusCode,
+				), nil
+			}
+
+			out, err := os.Create(outPath)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to create %q: %s", outPath, err.Error()), nil
+			}
+			written, err := io.Copy(out, dlResp.Body)
+			closeErr := out.Close()
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to write file to %q: %s", outPath, err.Error()), nil
+			}
+			if closeErr != nil {
+				return helpers.NewToolResultTextError("failed to finalise %q: %s", outPath, closeErr.Error()), nil
+			}
+
+			result := downloadFileResult{
+				SavedTo:  outPath,
+				FileName: fileName,
+				Bytes:    written,
+			}
+			encoded, err := json.Marshal(result)
+			if err != nil {
+				return nil, fmt.Errorf("failed to encode download result: %w", err)
+			}
+			return &mcp.CallToolResult{
+				Content: []mcp.Content{
+					&mcp.TextContent{Text: string(encoded)},
+				},
+				StructuredContent: result,
+			}, nil
+		},
+	}
+}
diff --git a/internal/twprojects/file_update.go b/internal/twprojects/file_update.go
new file mode 100644
index 0000000..29980a5
--- /dev/null
+++ b/internal/twprojects/file_update.go
@@ -0,0 +1,185 @@
+package twprojects
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// List of methods available in the Teamwork.com MCP service.
+const (
+	MethodFileUpdate toolsets.Method = "twprojects-update_file"
+)
+
+// fileUpdateRequest is a local HTTP requester for the v1 update-file endpoint.
+// The SDK models no file update, so the requester lives here (no twapi-go-sdk
+// edit). It edits a file's details (display name and/or description) in one
+// call — the same operation as the UI's "Edit File Details" — without any
+// download / re-upload / delete round-trip. It targets a file by its exact ID.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/files/put-files-id-json
+type fileUpdateRequest struct {
+	FileID      int64
+	Name        *string
+	Description *string
+}
+
+// HTTPRequest builds the PUT request carrying only the supplied fields.
+func (r fileUpdateRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	file := map[string]any{}
+	if r.Name != nil {
+		file["name"] = *r.Name
+	}
+	if r.Description != nil {
+		file["description"] = *r.Description
+	}
+	payload := map[string]any{"file": file}
+
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode file update request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/files/%d.json", server, r.FileID)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPut, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// UpdateFile edits an existing Teamwork file's details — its display name
+// (rename) and/or its description — in a single API call.
+func UpdateFile(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodFileUpdate),
+			Description: "Rename a Teamwork file or edit its details (display name and/or description) in a " +
+				"single call — the same operation as the UI's \"Edit File Details\". Use this instead of " +
+				"downloading, re-uploading and deleting a file just to change its name. Renaming changes " +
+				"only the file's display name in Teamwork (the underlying stored file and, for files linked " +
+				"from SharePoint/Google Drive/etc., the source file are unchanged); include the file " +
+				"extension in the new name. Pass the exact file_id and at least one of name or description. " +
+				"A file-version ID is not a file ID and will not resolve here — pass the file's own ID.",
+			Annotations: &mcp.ToolAnnotations{
+				Title: "Update File",
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"file_id": {
+						Type:        "integer",
+						Description: "The exact Teamwork file ID to update.",
+					},
+					"name": {
+						Description: "New display name for the file (include the extension, e.g. \"Report Q3.pdf\"). " +
+							"Omit to leave the name unchanged.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "string"},
+							{Type: "null"},
+						},
+					},
+					"description": {
+						Description: "New description for the file. Pass an empty string to clear it; omit to leave " +
+							"the description unchanged.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "string"},
+							{Type: "null"},
+						},
+					},
+				},
+				Required: []string{"file_id"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var fileID int64
+			if err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&fileID, "file_id"),
+			); err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			// Read name/description directly so we can distinguish "omitted"
+			// (leave unchanged) from "supplied empty string" (clear it).
+			var name, description *string
+			if raw, ok := arguments["name"]; ok && raw != nil {
+				s, ok := raw.(string)
+				if !ok {
+					return helpers.NewToolResultTextError("invalid parameters: name must be a string"), nil
+				}
+				name = &s
+			}
+			if raw, ok := arguments["description"]; ok && raw != nil {
+				s, ok := raw.(string)
+				if !ok {
+					return helpers.NewToolResultTextError("invalid parameters: description must be a string"), nil
+				}
+				description = &s
+			}
+
+			if name == nil && description == nil {
+				return helpers.NewToolResultTextError("provide at least one of name or description to update"), nil
+			}
+
+			resp, err := twapi.ExecuteRaw(ctx, engine, fileUpdateRequest{
+				FileID:      fileID,
+				Name:        name,
+				Description: description,
+			})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to update file")
+			}
+			body, readErr := io.ReadAll(resp.Body)
+			_ = resp.Body.Close()
+			if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(resp, "failed to update file"),
+					"failed to update file",
+				)
+			}
+			if readErr != nil {
+				return nil, fmt.Errorf("failed to read response body: %w", readErr)
+			}
+
+			// The v1 endpoint returns 200 with {"STATUS":"OK"} on success, but can
+			// also return 200 with {"STATUS":"Error"} for some failures — treat a
+			// non-OK STATUS as a failure so a bad update is never reported as success.
+			var status struct {
+				Status  string `json:"STATUS"`
+				Message string `json:"MESSAGE"`
+			}
+			_ = json.Unmarshal(body, &status)
+			if status.Status != "" && !strings.EqualFold(status.Status, "OK") {
+				msg := status.Message
+				if msg == "" {
+					msg = strings.TrimSpace(string(body))
+				}
+				return helpers.NewToolResultTextError("failed to update file %d: %s", fileID, msg), nil
+			}
+
+			switch {
+			case name != nil && description != nil:
+				return helpers.NewToolResultText("File %d renamed to %q and description updated.", fileID, *name), nil
+			case name != nil:
+				return helpers.NewToolResultText("File %d renamed to %q.", fileID, *name), nil
+			default:
+				return helpers.NewToolResultText("File %d description updated.", fileID), nil
+			}
+		},
+	}
+}
diff --git a/internal/twprojects/files.go b/internal/twprojects/files.go
new file mode 100644
index 0000000..e054d31
--- /dev/null
+++ b/internal/twprojects/files.go
@@ -0,0 +1,320 @@
+package twprojects
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"mime"
+	"mime/multipart"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// List of methods available in the Teamwork.com MCP service.
+const (
+	MethodFileUpload toolsets.Method = "twprojects-upload_file"
+)
+
+// pendingFileUploadRequest uploads a local file to Teamwork.com's pending
+// files area. It implements twapi.HTTPRequester so it can be executed by the
+// shared engine (which injects authentication). The returned pending file
+// reference is then attached to a task or project.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/file-uploads/post-pendingfiles-json
+type pendingFileUploadRequest struct {
+	Filename    string
+	ContentType string
+	Data        []byte
+}
+
+func (r pendingFileUploadRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	var body bytes.Buffer
+	writer := multipart.NewWriter(&body)
+
+	header := make(map[string][]string)
+	header["Content-Disposition"] = []string{
+		fmt.Sprintf(`form-data; name="file"; filename=%q`, r.Filename),
+	}
+	if r.ContentType != "" {
+		header["Content-Type"] = []string{r.ContentType}
+	}
+	part, err := writer.CreatePart(header)
+	if err != nil {
+		return nil, fmt.Errorf("failed to create multipart file part: %w", err)
+	}
+	if _, err := part.Write(r.Data); err != nil {
+		return nil, fmt.Errorf("failed to write file data: %w", err)
+	}
+	if err := writer.Close(); err != nil {
+		return nil, fmt.Errorf("failed to finalise multipart body: %w", err)
+	}
+
+	uri := fmt.Sprintf("%s/pendingfiles.json", server)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", writer.FormDataContentType())
+	return req, nil
+}
+
+// taskFileAttachRequest attaches one or more already-uploaded pending files to
+// an existing task via the v1 task update endpoint. Using
+// pendingFileAttachments adds the files without disturbing other task fields.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/tasks/put-tasks-id-json
+type taskFileAttachRequest struct {
+	TaskID         int64
+	PendingFileRef string
+}
+
+func (r taskFileAttachRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	payload := map[string]any{
+		"todo-item": map[string]any{
+			"pendingFileAttachments": r.PendingFileRef,
+		},
+	}
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode task attach request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/tasks/%d.json", server, r.TaskID)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPut, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// projectFileAttachRequest stores an already-uploaded pending file in a
+// project's Files area via the v1 project files endpoint.
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/files/post-projects-id-files-json
+type projectFileAttachRequest struct {
+	ProjectID      int64
+	PendingFileRef string
+}
+
+func (r projectFileAttachRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	payload := map[string]any{
+		"file": map[string]any{
+			"pendingFileRef": r.PendingFileRef,
+		},
+	}
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode project attach request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/projects/%d/files.json", server, r.ProjectID)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// commentFileAttachRequest posts a new comment on a task with an
+// already-uploaded pending file attached to that comment. The file shows in
+// the task's comment thread (and, like any task file, in the project's Files
+// area).
+//
+// https://apidocs.teamwork.com/docs/teamwork/v1/comments/post-tasks-id-comments-json
+type commentFileAttachRequest struct {
+	TaskID         int64
+	Body           string
+	PendingFileRef string
+}
+
+func (r commentFileAttachRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	payload := map[string]any{
+		"comment": map[string]any{
+			"body":                   r.Body,
+			"content-type":           "text",
+			"pendingFileAttachments": r.PendingFileRef,
+		},
+	}
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode comment attach request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/tasks/%d/comments.json", server, r.TaskID)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// FileUpload uploads a local file to Teamwork.com and attaches it to a task, a
+// project, or a new comment on a task. Exactly one of task_id or project_id
+// must be supplied; when comment is also provided, the file is attached to a
+// new comment on the task instead of directly to the task.
+func FileUpload(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodFileUpload),
+			Description: "Upload a local file and attach it to a task or a project's Files area. " +
+				"Provide the absolute file_path on disk plus exactly one of task_id or project_id.",
+			Annotations: &mcp.ToolAnnotations{
+				Title: "Upload File",
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"file_path": {
+						Type:        "string",
+						Description: "Absolute path to the local file to upload.",
+					},
+					"task_id": {
+						Description: "The ID of the task to attach the file to. Provide this OR project_id, not both.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "integer"},
+							{Type: "null"},
+						},
+					},
+					"project_id": {
+						Description: "The ID of the project to attach the file to (Files area). Provide this OR task_id, not both.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "integer"},
+							{Type: "null"},
+						},
+					},
+					"file_name": {
+						Description: "Optional override for the stored file name. Defaults to the file_path base name.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "string"},
+							{Type: "null"},
+						},
+					},
+					"comment": {
+						Description: "Optional comment text. When provided (with task_id), the file is attached to a new " +
+							"comment on the task instead of directly to the task.",
+						AnyOf: []*jsonschema.Schema{
+							{Type: "string"},
+							{Type: "null"},
+						},
+					},
+				},
+				Required: []string{"file_path"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var filePath, fileName, comment string
+			var taskID, projectID int64
+			err := helpers.ParamGroup(arguments,
+				helpers.RequiredParam(&filePath, "file_path"),
+				helpers.OptionalNumericParam(&taskID, "task_id"),
+				helpers.OptionalNumericParam(&projectID, "project_id"),
+				helpers.OptionalParam(&fileName, "file_name"),
+				helpers.OptionalParam(&comment, "comment"),
+			)
+			if err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			switch {
+			case taskID == 0 && projectID == 0:
+				return helpers.NewToolResultTextError("either task_id or project_id must be provided"), nil
+			case taskID != 0 && projectID != 0:
+				return helpers.NewToolResultTextError("provide only one of task_id or project_id, not both"), nil
+			case comment != "" && taskID == 0:
+				return helpers.NewToolResultTextError("comment can only be used together with task_id"), nil
+			}
+
+			data, err := os.ReadFile(filePath)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to read file %q: %s", filePath, err.Error()), nil
+			}
+			if fileName == "" {
+				fileName = filepath.Base(filePath)
+			}
+			contentType := mime.TypeByExtension(filepath.Ext(fileName))
+			if contentType == "" {
+				contentType = http.DetectContentType(data)
+			}
+
+			// Step 1: upload to the pending files area to obtain a reference.
+			uploadResp, err := twapi.ExecuteRaw(ctx, engine, pendingFileUploadRequest{
+				Filename:    fileName,
+				ContentType: contentType,
+				Data:        data,
+			})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to upload file")
+			}
+			defer func() { _ = uploadResp.Body.Close() }()
+			if uploadResp.StatusCode < 200 || uploadResp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(uploadResp, "failed to upload file"), "failed to upload file",
+				)
+			}
+			rawUpload, err := io.ReadAll(uploadResp.Body)
+			if err != nil {
+				return nil, fmt.Errorf("failed to read upload response body: %w", err)
+			}
+			var parsed struct {
+				PendingFile struct {
+					Ref string `json:"ref"`
+				} `json:"pendingFile"`
+			}
+			if err := json.Unmarshal(rawUpload, &parsed); err != nil {
+				return helpers.NewToolResultTextError(
+					"failed to parse upload response: %s (body: %s)", err.Error(), strings.TrimSpace(string(rawUpload)),
+				), nil
+			}
+			if parsed.PendingFile.Ref == "" {
+				return helpers.NewToolResultTextError(
+					"upload succeeded but no pending file reference was returned (body: %s)",
+					strings.TrimSpace(string(rawUpload)),
+				), nil
+			}
+			ref := parsed.PendingFile.Ref
+
+			// Step 2: attach the pending file to the chosen target.
+			var attachReq twapi.HTTPRequester
+			var target string
+			switch {
+			case comment != "":
+				attachReq = commentFileAttachRequest{TaskID: taskID, Body: comment, PendingFileRef: ref}
+				target = fmt.Sprintf("a new comment on task %d", taskID)
+			case taskID != 0:
+				attachReq = taskFileAttachRequest{TaskID: taskID, PendingFileRef: ref}
+				target = fmt.Sprintf("task %d", taskID)
+			default:
+				attachReq = projectFileAttachRequest{ProjectID: projectID, PendingFileRef: ref}
+				target = fmt.Sprintf("project %d", projectID)
+			}
+
+			attachResp, err := twapi.ExecuteRaw(ctx, engine, attachReq)
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to attach file")
+			}
+			defer func() { _ = attachResp.Body.Close() }()
+			if attachResp.StatusCode < 200 || attachResp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(attachResp, "failed to attach file"), "failed to attach file",
+				)
+			}
+
+			return helpers.NewToolResultText("Uploaded %q (ref %s) and attached to %s", fileName, ref, target), nil
+		},
+	}
+}
diff --git a/internal/twprojects/inline_image.go b/internal/twprojects/inline_image.go
new file mode 100644
index 0000000..d7faedd
--- /dev/null
+++ b/internal/twprojects/inline_image.go
@@ -0,0 +1,203 @@
+package twprojects
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"mime"
+	"net/http"
+	"net/url"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// Inline image upload.
+//
+// Pasting an image into a Teamwork rich-text field (a comment, description,
+// message, etc.) does NOT go through the pending-files attachment flow that
+// upload_file uses - that produces a file attachment, not a rendered image.
+// Instead the editor does a two-step presigned upload:
+//
+//  1. POST /projects/api/v3/inlineimage/presigned.json  {filename,size}
+//     -> {reference, uploadURL (presigned S3 PUT), downloadURL (public URL)}
+//  2. PUT the raw bytes to uploadURL (no Teamwork auth; the presigned URL is
+//     self-signed). The signature covers content-length;host;x-amz-acl, so the
+//     PUT MUST send x-amz-acl: public-read.
+//
+// The resulting image lives in the public tw-inlineimages bucket, so the
+// returned URL can be embedded directly in an HTML <img> tag in any rich-text
+// body (e.g. via create_comment with an HTML content type) and renders inline.
+const (
+	MethodInlineImageUpload toolsets.Method = "twprojects-upload_inline_image"
+)
+
+// inlineImagePresignRequest asks Teamwork for a presigned S3 upload URL for an
+// inline image. It implements twapi.HTTPRequester so the shared engine injects
+// the Teamwork bearer authentication.
+type inlineImagePresignRequest struct {
+	Filename string
+	Size     int
+}
+
+func (r inlineImagePresignRequest) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	payload := map[string]any{
+		"filename": r.Filename,
+		"size":     r.Size,
+	}
+	var body bytes.Buffer
+	if err := json.NewEncoder(&body).Encode(payload); err != nil {
+		return nil, fmt.Errorf("failed to encode inline image presign request: %w", err)
+	}
+	uri := fmt.Sprintf("%s/projects/api/v3/inlineimage/presigned.json", server)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, uri, &body)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// InlineImageUpload uploads a local image so it can be embedded as a rendered
+// inline image in a Teamwork rich-text body, and returns the public image URL.
+// This is distinct from upload_file, which produces a file attachment.
+func InlineImageUpload(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodInlineImageUpload),
+			Description: "Upload a local image and get back a public URL that renders as an inline image (not a " +
+				"file attachment). Use this when you want an image to display inside a comment, message or " +
+				"description - embed the returned url in an HTML <img> tag in the rich-text body (e.g. call " +
+				"create_comment with an HTML content type and body like <img src=\"...\">). Provide the absolute " +
+				"file_path on disk. This is different from upload_file, which attaches the image as a downloadable " +
+				"file rather than showing it inline.",
+			Annotations: &mcp.ToolAnnotations{
+				Title: "Upload Inline Image",
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"file_path": {
+						Type:        "string",
+						Description: "Absolute path to the local image file to upload (e.g. a PNG or JPEG screenshot).",
+					},
+					"file_name": {
+						Description: "Optional override for the uploaded file name (include the extension). " +
+							"Defaults to the file_path base name.",
+						AnyOf: []*jsonschema.Schema{{Type: "string"}, {Type: "null"}},
+					},
+				},
+				Required: []string{"file_path"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var filePath, fileName string
+			if err := helpers.ParamGroup(arguments,
+				helpers.RequiredParam(&filePath, "file_path"),
+				helpers.OptionalParam(&fileName, "file_name"),
+			); err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			data, err := os.ReadFile(filePath)
+			if err != nil {
+				return helpers.NewToolResultTextError("failed to read file %q: %s", filePath, err.Error()), nil
+			}
+			if fileName == "" {
+				fileName = filepath.Base(filePath)
+			}
+			contentType := mime.TypeByExtension(filepath.Ext(fileName))
+			if contentType == "" {
+				contentType = http.DetectContentType(data)
+			}
+
+			// Step 1: ask Teamwork for a presigned upload URL.
+			presignResp, err := twapi.ExecuteRaw(ctx, engine, inlineImagePresignRequest{
+				Filename: fileName,
+				Size:     len(data),
+			})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to request inline image upload URL")
+			}
+			presignBody, _ := io.ReadAll(presignResp.Body)
+			_ = presignResp.Body.Close()
+			if presignResp.StatusCode < 200 || presignResp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(presignResp, "failed to request inline image upload URL"),
+					"failed to request inline image upload URL")
+			}
+			var presign struct {
+				Reference   string `json:"reference"`
+				UploadURL   string `json:"uploadURL"`
+				DownloadURL string `json:"downloadURL"`
+			}
+			if err := json.Unmarshal(presignBody, &presign); err != nil {
+				return helpers.NewToolResultTextError(
+					"failed to parse presign response: %s (body: %s)", err.Error(), strings.TrimSpace(string(presignBody))), nil
+			}
+			if presign.UploadURL == "" {
+				return helpers.NewToolResultTextError(
+					"presign succeeded but no uploadURL was returned (body: %s)", strings.TrimSpace(string(presignBody))), nil
+			}
+
+			// Step 2: PUT the bytes to the presigned S3 URL. The presigned
+			// signature covers x-amz-acl, so it must be sent as public-read.
+			putReq, err := http.NewRequestWithContext(ctx, http.MethodPut, presign.UploadURL, bytes.NewReader(data))
+			if err != nil {
+				return nil, fmt.Errorf("failed to build inline image upload request: %w", err)
+			}
+			putReq.Header.Set("x-amz-acl", "public-read")
+			putReq.Header.Set("Content-Type", contentType)
+			putReq.ContentLength = int64(len(data))
+			putResp, err := http.DefaultClient.Do(putReq)
+			if err != nil {
+				return helpers.NewToolResultTextError("inline image upload failed: %s", err.Error()), nil
+			}
+			putBody, _ := io.ReadAll(putResp.Body)
+			_ = putResp.Body.Close()
+			if putResp.StatusCode < 200 || putResp.StatusCode >= 300 {
+				return helpers.NewToolResultTextError(
+					"inline image upload returned status %d: %s", putResp.StatusCode, strings.TrimSpace(string(putBody))), nil
+			}
+
+			// The public display URL: prefer the API's downloadURL, else the
+			// uploadURL with its presigned query stripped.
+			displayURL := presign.DownloadURL
+			if displayURL == "" {
+				if u, perr := url.Parse(presign.UploadURL); perr == nil {
+					u.RawQuery = ""
+					displayURL = u.String()
+				}
+			}
+
+			out := struct {
+				URL       string `json:"url"`
+				Reference string `json:"reference"`
+				FileName  string `json:"file_name"`
+				HTML      string `json:"html_snippet"`
+				Message   string `json:"message"`
+			}{
+				URL:       displayURL,
+				Reference: presign.Reference,
+				FileName:  fileName,
+				HTML:      fmt.Sprintf(`<img src=%q alt=%q>`, displayURL, fileName),
+				Message: "Uploaded as an inline image. Embed the html_snippet (or url in an <img> tag) in a " +
+					"rich-text body - e.g. create_comment with an HTML content type - to render it inline.",
+			}
+			return helpers.NewToolResultJSON(out)
+		},
+	}
+}
diff --git a/internal/twprojects/message_category.go b/internal/twprojects/message_category.go
new file mode 100644
index 0000000..4b28280
--- /dev/null
+++ b/internal/twprojects/message_category.go
@@ -0,0 +1,500 @@
+package twprojects
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"sort"
+	"strconv"
+	"strings"
+
+	"github.com/google/jsonschema-go/jsonschema"
+	"github.com/modelcontextprotocol/go-sdk/mcp"
+	"github.com/teamwork/mcp/internal/helpers"
+	"github.com/teamwork/mcp/internal/toolsets"
+	twapi "github.com/teamwork/twapi-go-sdk"
+)
+
+// Message-category tools. The stock tw-mcp binary has no way to list or set a
+// message's category, so these are local requesters over the Teamwork v1 REST
+// API (no twapi-go-sdk edit).
+const (
+	MethodSetMessageCategory    toolsets.Method = "twprojects-set_message_category"
+	MethodListMessageCategories toolsets.Method = "twprojects-list_message_categories"
+)
+
+// --- requesters --------------------------------------------------------------
+
+// messageGetRequester fetches a single message so we can read its project id.
+type messageGetRequester struct {
+	messageID int64
+}
+
+func (r messageGetRequester) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/messages/%d.json", server, r.messageID)
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+// messageCategoriesRequester lists the message categories defined on a project.
+type messageCategoriesRequester struct {
+	projectID int64
+}
+
+func (r messageCategoriesRequester) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/projects/%d/messageCategories.json", server, r.projectID)
+	return http.NewRequestWithContext(ctx, http.MethodGet, uri, nil)
+}
+
+// messageSetCategoryRequester PUTs a new category id onto a message. A
+// category id of 0 clears the message's category.
+type messageSetCategoryRequester struct {
+	messageID  int64
+	categoryID int64
+}
+
+func (r messageSetCategoryRequester) HTTPRequest(ctx context.Context, server string) (*http.Request, error) {
+	uri := fmt.Sprintf("%s/messages/%d.json", server, r.messageID)
+	body := struct {
+		Post struct {
+			CategoryID int64 `json:"category-id"`
+		} `json:"post"`
+	}{}
+	body.Post.CategoryID = r.categoryID
+	var buf bytes.Buffer
+	if err := json.NewEncoder(&buf).Encode(body); err != nil {
+		return nil, fmt.Errorf("failed to encode set message category request: %w", err)
+	}
+	req, err := http.NewRequestWithContext(ctx, http.MethodPut, uri, &buf)
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	return req, nil
+}
+
+// --- response shapes (v1 API — hyphenated keys, ids often quoted strings) ----
+
+// flexID leniently decodes an id that the v1 API may return as a quoted string
+// ("123"), a bare number (123), an empty string (""), or null — all normalised
+// to a trimmed decimal string ("" when absent). json.Number can't handle the
+// empty-string case (top-level categories return parent-id ""), which is why
+// this exists.
+type flexID string
+
+func (f *flexID) UnmarshalJSON(data []byte) error {
+	s := strings.TrimSpace(string(data))
+	if s == "" || s == "null" {
+		*f = ""
+		return nil
+	}
+	if s[0] == '"' {
+		var str string
+		if err := json.Unmarshal(data, &str); err != nil {
+			return err
+		}
+		*f = flexID(strings.TrimSpace(str))
+		return nil
+	}
+	*f = flexID(s)
+	return nil
+}
+
+func (f flexID) String() string { return string(f) }
+
+// rawMessage is the subset of GET /messages/{id}.json the tool reads. v1
+// nests the record under "post" (older installs use "message"); ids come back
+// as quoted strings, so flexID tolerates string/number/empty forms.
+type rawMessage struct {
+	ProjectID flexID `json:"project-id"`
+}
+
+type rawMessageResponse struct {
+	Post    *rawMessage `json:"post"`
+	Message *rawMessage `json:"message"`
+}
+
+func (r rawMessageResponse) record() *rawMessage {
+	if r.Post != nil {
+		return r.Post
+	}
+	return r.Message
+}
+
+// rawCategory is one entry from GET /projects/{id}/messageCategories.json.
+type rawCategory struct {
+	ID       flexID `json:"id"`
+	Name     string `json:"name"`
+	ParentID flexID `json:"parent-id"`
+}
+
+// rawCategoriesResponse tolerates both key spellings seen across installs.
+type rawCategoriesResponse struct {
+	Categories        []rawCategory `json:"categories"`
+	MessageCategories []rawCategory `json:"messageCategories"`
+}
+
+func (r rawCategoriesResponse) list() []rawCategory {
+	if len(r.Categories) > 0 {
+		return r.Categories
+	}
+	return r.MessageCategories
+}
+
+// --- category tree helpers ---------------------------------------------------
+
+type categoryNode struct {
+	name   string
+	parent string
+}
+
+// buildCategoryTree maps category id -> {name, parent}. Ids are normalised to
+// their decimal string form so lookups are consistent regardless of whether
+// the API returned them quoted or numeric.
+func buildCategoryTree(cats []rawCategory) map[string]categoryNode {
+	tree := make(map[string]categoryNode, len(cats))
+	for _, c := range cats {
+		id := strings.TrimSpace(c.ID.String())
+		if id == "" {
+			continue
+		}
+		parent := strings.TrimSpace(c.ParentID.String())
+		if parent == "0" {
+			parent = ""
+		}
+		tree[id] = categoryNode{name: c.Name, parent: parent}
+	}
+	return tree
+}
+
+// categoryPath renders the "Parent > Child" path for a category id, walking up
+// the parent chain. Cycle-safe.
+func categoryPath(tree map[string]categoryNode, id string) string {
+	var names []string
+	seen := make(map[string]bool)
+	for id != "" && !seen[id] {
+		seen[id] = true
+		node, ok := tree[id]
+		if !ok {
+			break
+		}
+		if node.name != "" {
+			names = append(names, node.name)
+		}
+		id = node.parent
+	}
+	// reverse
+	for i, j := 0, len(names)-1; i < j; i, j = i+1, j-1 {
+		names[i], names[j] = names[j], names[i]
+	}
+	return strings.Join(names, " > ")
+}
+
+// resolveCategory maps a human path/leaf ("Time Reporting > 2026" or "2026")
+// to a category id within the tree. Returns the id and its full path, or an
+// error describing why (not found / ambiguous), listing the available paths.
+func resolveCategory(tree map[string]categoryNode, pathInput string) (string, string, error) {
+	if len(tree) == 0 {
+		return "", "", fmt.Errorf("this project has no message categories")
+	}
+	segments := make([]string, 0)
+	for _, s := range strings.Split(pathInput, ">") {
+		if s = strings.TrimSpace(s); s != "" {
+			segments = append(segments, s)
+		}
+	}
+	if len(segments) == 0 {
+		return "", "", fmt.Errorf("empty category_path")
+	}
+	wantFull := strings.ToLower(strings.Join(segments, " > "))
+	wantLeaf := strings.ToLower(segments[len(segments)-1])
+
+	type match struct{ id, full string }
+	var matches []match
+	for id, node := range tree {
+		full := categoryPath(tree, id)
+		if len(segments) > 1 {
+			if strings.EqualFold(full, wantFull) {
+				matches = append(matches, match{id, full})
+			}
+		} else if strings.ToLower(node.name) == wantLeaf {
+			matches = append(matches, match{id, full})
+		}
+	}
+	switch len(matches) {
+	case 1:
+		return matches[0].id, matches[0].full, nil
+	case 0:
+		avail := make([]string, 0, len(tree))
+		for id := range tree {
+			avail = append(avail, categoryPath(tree, id))
+		}
+		return "", "", fmt.Errorf("no category matches %q. Available: %s",
+			pathInput, strings.Join(avail, "; "))
+	default:
+		opts := make([]string, 0, len(matches))
+		for _, m := range matches {
+			opts = append(opts, fmt.Sprintf("%s (id %s)", m.full, m.id))
+		}
+		return "", "", fmt.Errorf("%q is ambiguous — matches: %s. Re-run with the full path or category_id",
+			pathInput, strings.Join(opts, "; "))
+	}
+}
+
+// --- tool --------------------------------------------------------------------
+
+// SetMessageCategory sets or clears the category of a Teamwork message. Provide
+// message_id plus EITHER category_id (numeric; 0 clears) OR category_path (a
+// human path resolved within the message's own project).
+func SetMessageCategory(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodSetMessageCategory),
+			Description: "Set (or clear) the category of a Teamwork message. Provide message_id plus " +
+				"EITHER category_id (the numeric id) OR category_path (a human path resolved within " +
+				"the message's project, e.g. 'Time Reporting > 2026'). To clear the category, pass " +
+				"category_id = 0. Find category ids/paths via the message's project message categories.",
+			Annotations: &mcp.ToolAnnotations{
+				Title: "Set Message Category",
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"message_id": {
+						Type:        "integer",
+						Description: "ID of the message whose category to set.",
+					},
+					"category_id": {
+						Type:        "integer",
+						Description: "Numeric category id to assign; 0 clears the category. Omit to resolve by category_path.",
+					},
+					"category_path": {
+						Type: "string",
+						Description: "Category path or leaf name to resolve within the message's project, " +
+							"e.g. 'Time Reporting > 2026'. Ignored when category_id is given.",
+					},
+				},
+				Required: []string{"message_id"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+
+			var messageID, categoryID int64
+			var categoryPathArg string
+			err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&messageID, "message_id"),
+				helpers.OptionalNumericParam(&categoryID, "category_id"),
+				helpers.OptionalParam(&categoryPathArg, "category_path"),
+			)
+			if err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+			_, hasCategoryID := arguments["category_id"]
+
+			resolvedPath := ""
+			if !hasCategoryID {
+				// Resolve by path: need the message's project, then its categories.
+				if strings.TrimSpace(categoryPathArg) == "" {
+					return helpers.NewToolResultTextError(
+						"provide either category_id (0 to clear) or category_path"), nil
+				}
+				projectID, apiErr := fetchMessageProjectID(ctx, engine, messageID)
+				if apiErr != nil {
+					return apiErr, nil
+				}
+				tree, apiErr2 := fetchCategoryTree(ctx, engine, projectID)
+				if apiErr2 != nil {
+					return apiErr2, nil
+				}
+				id, full, resErr := resolveCategory(tree, categoryPathArg)
+				if resErr != nil {
+					return helpers.NewToolResultTextError("%s", resErr.Error()), nil
+				}
+				parsed, convErr := strconv.ParseInt(id, 10, 64)
+				if convErr != nil {
+					return helpers.NewToolResultTextError("resolved category id %q is not numeric", id), nil
+				}
+				categoryID = parsed
+				resolvedPath = full
+			}
+
+			resp, err := twapi.ExecuteRaw(ctx, engine,
+				messageSetCategoryRequester{messageID: messageID, categoryID: categoryID})
+			if err != nil {
+				return helpers.HandleAPIError(err, "failed to set message category")
+			}
+			_, readErr := io.ReadAll(resp.Body)
+			_ = resp.Body.Close()
+			if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+				return helpers.HandleAPIError(
+					twapi.NewHTTPError(resp, "failed to set message category"),
+					"failed to set message category",
+				)
+			}
+			if readErr != nil {
+				return nil, fmt.Errorf("failed to read response body: %w", readErr)
+			}
+
+			if categoryID == 0 {
+				return helpers.NewToolResultText("Cleared category on message %d.", messageID), nil
+			}
+			if resolvedPath != "" {
+				return helpers.NewToolResultText(
+					"Set category of message %d to %q (id %d).", messageID, resolvedPath, categoryID), nil
+			}
+			return helpers.NewToolResultText(
+				"Set category of message %d to id %d.", messageID, categoryID), nil
+		},
+	}
+}
+
+// messageCategory is one entry returned by list_message_categories.
+type messageCategory struct {
+	ID   int64  `json:"id"`
+	Name string `json:"name"`
+	Path string `json:"path"`
+}
+
+type listMessageCategoriesResult struct {
+	ProjectID  int64             `json:"project_id"`
+	Returned   int               `json:"returned"`
+	Categories []messageCategory `json:"categories"`
+}
+
+// ListMessageCategories lists the message categories defined on a project, so
+// the caller can discover valid ids/paths before calling set_message_category.
+// These are MESSAGE categories, a separate id space from project categories
+// (list_project_categories).
+func ListMessageCategories(engine *twapi.Engine) toolsets.ToolWrapper {
+	return toolsets.ToolWrapper{
+		Tool: &mcp.Tool{
+			Name: string(MethodListMessageCategories),
+			Description: "List the message categories defined on a project. Use this to discover valid " +
+				"category ids and paths before calling set_message_category. Returns each category's id, " +
+				"name and full path (e.g. 'Time Reporting > 2026'). NOTE: these are MESSAGE categories, a " +
+				"separate id space from project categories (list_project_categories) — do not mix them.",
+			Annotations: &mcp.ToolAnnotations{
+				Title:        "List Message Categories",
+				ReadOnlyHint: true,
+			},
+			InputSchema: &jsonschema.Schema{
+				Type: "object",
+				Properties: map[string]*jsonschema.Schema{
+					"project_id": {
+						Type:        "integer",
+						Description: "The ID of the project whose message categories to list.",
+					},
+				},
+				Required: []string{"project_id"},
+			},
+		},
+		Handler: func(ctx context.Context, request *mcp.CallToolRequest) (*mcp.CallToolResult, error) {
+			var arguments map[string]any
+			if err := json.Unmarshal(request.Params.Arguments, &arguments); err != nil {
+				return helpers.NewToolResultTextError("failed to decode request: %s", err.Error()), nil
+			}
+			var projectID int64
+			if err := helpers.ParamGroup(arguments,
+				helpers.RequiredNumericParam(&projectID, "project_id"),
+			); err != nil {
+				return helpers.NewToolResultTextError("invalid parameters: %s", err.Error()), nil
+			}
+
+			tree, apiErr := fetchCategoryTree(ctx, engine, projectID)
+			if apiErr != nil {
+				return apiErr, nil
+			}
+
+			result := listMessageCategoriesResult{ProjectID: projectID, Categories: []messageCategory{}}
+			for id, node := range tree {
+				parsed, convErr := strconv.ParseInt(id, 10, 64)
+				if convErr != nil {
+					continue
+				}
+				result.Categories = append(result.Categories, messageCategory{
+					ID:   parsed,
+					Name: node.name,
+					Path: categoryPath(tree, id),
+				})
+			}
+			// Stable order: by path, then id.
+			sort.Slice(result.Categories, func(i, j int) bool {
+				if result.Categories[i].Path == result.Categories[j].Path {
+					return result.Categories[i].ID < result.Categories[j].ID
+				}
+				return result.Categories[i].Path < result.Categories[j].Path
+			})
+			result.Returned = len(result.Categories)
+
+			var buf bytes.Buffer
+			enc := json.NewEncoder(&buf)
+			enc.SetEscapeHTML(false) // keep ">" in category paths readable, not >
+			if marshalErr := enc.Encode(result); marshalErr != nil {
+				return nil, fmt.Errorf("failed to encode categories: %w", marshalErr)
+			}
+			return helpers.NewToolResultText("%s", strings.TrimSpace(buf.String())), nil
+		},
+	}
+}
+
+// fetchMessageProjectID reads a message and returns its project id.
+func fetchMessageProjectID(ctx context.Context, engine *twapi.Engine, messageID int64) (int64, *mcp.CallToolResult) {
+	resp, err := twapi.ExecuteRaw(ctx, engine, messageGetRequester{messageID: messageID})
+	if err != nil {
+		r, _ := helpers.HandleAPIError(err, "failed to fetch message")
+		return 0, r
+	}
+	body, readErr := io.ReadAll(resp.Body)
+	_ = resp.Body.Close()
+	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+		r, _ := helpers.HandleAPIError(
+			twapi.NewHTTPError(resp, "failed to fetch message"), "failed to fetch message")
+		return 0, r
+	}
+	if readErr != nil {
+		return 0, helpers.NewToolResultTextError("failed to read message response: %s", readErr.Error())
+	}
+	var decoded rawMessageResponse
+	if err := json.Unmarshal(body, &decoded); err != nil {
+		return 0, helpers.NewToolResultTextError("failed to decode message response: %s", err.Error())
+	}
+	rec := decoded.record()
+	if rec == nil {
+		return 0, helpers.NewToolResultTextError("message %d not found", messageID)
+	}
+	pid, err := strconv.ParseInt(strings.TrimSpace(rec.ProjectID.String()), 10, 64)
+	if err != nil || pid == 0 {
+		return 0, helpers.NewToolResultTextError("could not determine the project for message %d", messageID)
+	}
+	return pid, nil
+}
+
+// fetchCategoryTree loads a project's message categories as an id->node tree.
+func fetchCategoryTree(ctx context.Context, engine *twapi.Engine, projectID int64) (map[string]categoryNode, *mcp.CallToolResult) {
+	resp, err := twapi.ExecuteRaw(ctx, engine, messageCategoriesRequester{projectID: projectID})
+	if err != nil {
+		r, _ := helpers.HandleAPIError(err, "failed to fetch message categories")
+		return nil, r
+	}
+	body, readErr := io.ReadAll(resp.Body)
+	_ = resp.Body.Close()
+	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+		r, _ := helpers.HandleAPIError(
+			twapi.NewHTTPError(resp, "failed to fetch message categories"), "failed to fetch message categories")
+		return nil, r
+	}
+	if readErr != nil {
+		return nil, helpers.NewToolResultTextError("failed to read categories response: %s", readErr.Error())
+	}
+	var decoded rawCategoriesResponse
+	if err := json.Unmarshal(body, &decoded); err != nil {
+		return nil, helpers.NewToolResultTextError("failed to decode categories response: %s", err.Error())
+	}
+	return buildCategoryTree(decoded.list()), nil
+}
