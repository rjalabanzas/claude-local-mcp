# Keep line endings deterministic across macOS and Windows checkouts.
# Without this, Git for Windows (autocrlf=true) rewrites these to CRLF, which
# breaks bash execution under Git Bash and makes `git apply` reject the patches.
* text=auto eol=lf

*.sh    text eol=lf
*.py    text eol=lf
*.patch -text
*.json  text eol=lf

# Treat compiled/binary artifacts as binary (never line-ending converted).
*.png binary
*.exe binary
