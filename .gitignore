# ── secrets: NEVER commit ────────────────────────────────────────────────
.env
*.env
**/.env
*token*
*tokens.json
*.secret
*.pem
*.key
claude_desktop_config.json
*.bak-*

# ── per-machine auth / session state ─────────────────────────────────────
*.session
*.session-journal
**/store/*.db
**/whatsapp-bridge/store/
~/.config/readai-mcp/

# ── build artifacts (rebuilt by setup.sh) ────────────────────────────────
servers/teamwork/bin/
servers/teamwork/.build/
**/node_modules/
**/dist/
**/.venv/
**/__pycache__/
*.pyc
# vendored Go bridge: keep source, ignore compiled binary
servers/whatsapp/**/whatsapp-bridge/whatsapp-bridge

# ── os cruft ─────────────────────────────────────────────────────────────
.DS_Store
